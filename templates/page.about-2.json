op","image_behavior":"none","padding-block-start":30,"padding-block-end":30,"padding-inline-start":0,"padding-inline-end":0,"custom_padding_more_devices":false,"padding-block-start-tl":0,"padding-block-end-tl":0,"padding-inline-start-tl":0,"padding-inline-end-tl":0,"padding-block-start-mb":0,"padding-block-end-mb":0,"padding-inline-start-mb":0,"padding-inline-end-mb":0}},"custom_liquid_bL7RGN":{"type":"custom-liquid","name":"t:names.custom_liquid","settings":{"custom_liquid":"<style>\n.ur-about{\n  max-width:900px;\n  margin:60px auto;\n  padding:0 20px;\n  font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;\n  color:#111;\n}\n\n.ur-about h1{\n  font-size:38px;\n  font-weight:600;\n  margin-bottom:15px;\n}\n\n.ur-about h2{\n  font-size:24px;\n  font-weight:600;\n  margin:0 0 15px;\n}\n\n.ur-about p{\n  color:#666;\n  line-height:1.8;\n  margin-bottom:18px;\n}\n\n.ur-divider{\n  border-top:1px solid #ececec;\n  margin:45px 0;\n}\n\n.ur-list{\n  margin:0;\n  padding-left:20px;\n}\n\n.ur-list li{\n  margin-bottom:12px;\n  color:#555;\n  line-height:1.7;\n}\n\n.ur-btn{\n  display:inline-block;\n  margin-top:18px;\n  padding:12px 24px;\n  background:#111;\n  color:#fff !important;\n  text-decoration:none;\n  border-radius:4px;\n  font-weight:500;\n}\n\n.ur-btn:hover{\n  opacity:.9;\n}\n\n@media(max-width:749px){\n\n.ur-about{\nmargin:40px auto;\npadding:0 18px;\n}\n\n.ur-about h1{\nfont-size:30px;\n}\n\n.ur-about h2{\nfont-size:22px;\n}\n\n}\n<\/style>\n\n<div class=\"ur-about\">\n\n<h1>About Universes RAW<\/h1>\n\n<p>\nAt <strong>Universes RAW<\/strong>, we believe premium fashion should be timeless, comfortable, and accessible. For over <strong>5 years<\/strong>, we've proudly served customers across Bangladesh with carefully selected premium imported menswear that combines quality, craftsmanship, and modern style.\n<\/p>\n\n<div class=\"ur-divider\"><\/div>\n\n<h2>Our Story<\/h2>\n\n<p>\nFounded with a passion for premium fashion, Universes RAW has grown into a trusted destination for imported men's clothing and footwear. Our mission has always been simple—offer exceptional products, honest service, and an enjoyable shopping experience for every customer.\n<\/p>\n\n<p>\nEvery collection is carefully selected to ensure it meets our standards for quality, comfort, and design. Whether you're shopping for everyday essentials or statement pieces, we're committed to helping you dress with confidence.\n<\/p>\n\n<div class=\"ur-divider\"><\/div>\n\n<h2>What We Offer<\/h2>\n\n<ul class=\"ur-list\">\n<li>Premium Imported Polo Shirts<\/li>\n<li>Premium Shirts<\/li>\n<li>T-Shirts<\/li>\n<li>Denim & Trousers<\/li>\n<li>Sneakers<\/li>\n<li>Loafers<\/li>\n<li>Boots<\/li>\n<li>Jackets & Hoodies<\/li>\n<li>Accessories<\/li>\n<\/ul>\n\n<div class=\"ur-divider\"><\/div>\n\n<h2>Why Choose Universes RAW?<\/h2>\n\n<ul class=\"ur-list\">\n<li>Over 5 years of experience in premium imported fashion.<\/li>\n<li>Carefully selected products with a focus on quality.<\/li>\n<li>Reliable customer support before and after every purchase.<\/li>\n<li>Nationwide delivery across Bangladesh.<\/li>\n<li>A seamless online and in-store shopping experience.<\/li>\n<\/ul>\n\n<div class=\"ur-divider\"><\/div>\n\n<h2>Our Mission<\/h2>\n\n<p>\nTo provide premium imported menswear with exceptional quality, reliable customer service, and a shopping experience our customers can trust.\n<\/p>\n\n<div class=\"ur-divider\"><\/div>\n\n<h2>Our Vision<\/h2>\n\n<p>\nTo become one of Bangladesh's most trusted destinations for premium men's fashion by continuously delivering quality products, outstanding service, and long-term customer satisfaction.\n<\/p>\n\n<div class=\"ur-divider\"><\/div>\n\n<h2>Visit Our Showrooms<\/h2>\n\n<p>\nExperience our collections in person and discover the quality of Universes RAW firsthand.\n<\/p>\n\n<a href=\"\/pages\/store-locator\" class=\"ur-btn\">\nView Store Locator\n<\/a>\n\n<div class=\"ur-divider\"><\/div>\n\n<h2>Need Assistance?<\/h2>\n\n<p>\nHave questions or need help with an order? Our team is always ready to assist you.\n<\/p>\n\n<p>\n<strong>Call:<\/strong><br>\n<a href=\"tel:+8809643655867\">+880 9643-655867<\/a>\n<\/p>\n\n<p>\n<strong>WhatsApp:<\/strong><br>\n<a href=\"https:\/\/wa.me\/8801805205867\" target=\"_blank\">Chat on WhatsApp<\/a>\n<\/p>\n\n<p>\n<strong>Email:<\/strong><br>\n<a href=\"mailto:info@universesraw.com\">info@universesraw.com<\/a>\n<\/p>\n\n<div class=\"ur-divider\"><\/div>\n\n<p style=\"margin-bottom:0;\">\n<strong>Thank you for choosing Universes RAW.<\/strong><br>\nWe're proud to have served customers across Bangladesh for more than five years and look forward to continuing our journey with you.\n<\/p>\n\n<\/div>","color_scheme":"","padding_top":40,"padding_bottom":52}}},"order":["main","section_9RC8nk","section_fdhJYa","section_c8X8Aq","custom_liquid_bL7RGN"]}