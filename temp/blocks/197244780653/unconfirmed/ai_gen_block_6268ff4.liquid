  "name": "Luxury hero",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "label": "Desktop height",
      "min": 70,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 95
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Mobile height",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 85
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 1200,
      "max": 1920,
      "step": 40,
      "unit": "px",
      "default": 1600
    },
    {
      "type": "range",
      "id": "container_padding",
      "label": "Container padding",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Premium Collection"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "eyebrow_spacing",
      "label": "Eyebrow letter spacing",
      "min": 1,
      "max": 5,
