{% doc %}
  @prompt
    creat the Shopify Featured Products section to match the premium editorial fashion aesthetic shown in the reference image.
    
    DO NOT create a generic Shopify product grid.
    
    The section should feel like a luxury fashion brand similar to COS, ARKET, Fear of God, or the reference design.
    
    ====================
    SECTION HEADER
    ====================
    
    Create a clean editorial header.
    
    Top left:
    Small uppercase label:
    "THE EDIT"
    
    Style:
    - Font Size: 11px
    - Letter Spacing: 0.25em
    - Font Weight: 600
    - Color: #C23A45
    
    Below it:
    
    Large serif heading:
    
    Featured selection
    
    Use an elegant editorial serif font similar to:
    Canela
    Cormorant Garamond
    PP Editorial New
    
    Desktop:
    46px
    
    Mobile:
    34px
    
    Weight:
    400
    
    Color:
    #111111
    
    Below heading:
    
    Handpicked pieces from our latest drop.
    
    Font:
    Inter
    
    16px
    
    Color:
    #666
    
    On the right side:
    
    SHOP ALL
    
    Uppercase
    
    Letter spacing:
    0.35em
    
    Small underline
    
    Hover animation:
    Underline expands smoothly.
    
    ====================
    LAYOUT
    ====================
    
    Desktop:
    4 products per row
    
    Tablet:
    3 products
    
    Mobile:
    2 products
    
    Large white spacing
    
    Modern editorial alignment
    
    Maximum width:
    1400px
    
    Section padding:
    
    Desktop:
    100px top
    80px bottom
    
    Mobile:
    48px
    
    ====================
    PRODUCT CARD
    ====================
    
    Premium minimal product card.
    
    No visible border.
    
    White background.
    
    Image container:
    
    Rounded corners:
    18px
    
    Background:
    #F6F6F6
    
    Overflow hidden.
    
    Hover:
    
    Image zoom:
    scale(1.04)
    
    Transition:
    400ms cubic-bezier(.22,.61,.36,1)
    
    Shadow:
    
    0 20px 60px rgba(0,0,0,.08)
    
    Entire card lifts:
    translateY(-4px)
    
    ====================
    SALE BADGE
    ====================
    
    Top left
    
    Dynamic Shopify discount percentage.
    
    Example:
    
    -26%
    
    Background:
    #BE2332
    
    White text
    
    Border radius:
    999px
    
    Height:
    24px
    
    Padding:
    6px 10px
    
    Font:
    11px
    
    Weight:
    600
    
    ====================
    PRODUCT IMAGE
    ====================
    
    Large image.
    
    Centered.
    
    Object-fit:
    contain
    
    Maintain original product ratio.
    
    Hover:
    
    Fade into second product image if available.
    
    Smooth transition.
    
    ====================
    PRODUCT INFORMATION
    ====================
    
    Brand
    
    Uppercase
    
    Letter spacing:
    0.22em
    
    11px
    
    Color:
    #777
    
    Product Title
    
    15px
    
    Medium weight
    
    Maximum:
    2 lines
    
    Clamp after two lines.
    
    Price
    
    Current price:
    
    18px
    
    Weight:
    700
    
    Old price:
    
    14px
    
    Gray
    
    Line-through
    
    Dynamic Shopify pricing.
    
    ====================
    COLOR SWATCHES
    ====================
    
    Display available color variants.
    
    Small circles
    
    10px
    
    Gap:
    8px
    
    Active color:
    
    Black border
    
    Hover:
    
    Scale slightly.
    
    ====================
    SIZE OPTIONS
    ====================
    
    Display available sizes.
    
    Example:
    
    40 · 41 · 42 · 43 · 44
    
    Font:
    11px
    
    Color:
    #777
    
    Spacing:
    6px
    
    ====================
    QUICK ADD
    ====================
    
    Desktop:
    
    Quick Add button slides up over image on hover.
    
    Button:
    
    Black background
    
    White text
    
    Rounded
    
    Height:
    42px
    
    Smooth animation.
    
    Mobile:
    
    Always visible.
    
    ====================
    SHOPIFY FEATURES
    ====================
    
    Use Shopify Featured Collection.
    
    Dynamic Products
    
    Dynamic Prices
    
    Dynamic Compare-at Price
    
    Dynamic Discount Percentage
    
    Dynamic Variants
    
    Dynamic Images
    
    Dynamic Quick Add
    
    Shopify Theme Editor compatible.
    
    No hardcoded products.
    
    ====================
    ANIMATIONS
    ====================
    
    Fade in when section enters viewport.
    
    Hover:
    
    Image zoom
    
    Card lift
    
    Button slide
    
    Second image fade
    
    Wishlist icon fade
    
    Everything should animate smoothly using CSS transitions.
    
    ====================
    DESIGN STYLE
    ====================
    
    The final result should look identical in quality to the provided reference.
    
    Luxury.
    
    Editorial.
    
    Minimal.
    
    Premium.
    
    Fashion-forward.
    
    Apple-level spacing.
    
    No unnecessary borders.
    
    No heavy shadows.
    
    Excellent typography.
    
    Perfect mobile responsiveness.
    
    Fast loading.
    
    Clean semantic HTML.
    
    Use Liquid, CSS, and vanilla JavaScript only.
    
    The section should be fully customizable from the Shopify Theme Editor, allowing changes to the heading, subheading, button text, collection source, number of products, colors, spacing, and typography without modifying the code.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-products-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-featured-products-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px 16px {{ block.settings.section_padding_bottom_mobile }}px;
    }
  }

  .ai-featured-products-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-featured-products-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: {{ block.settings.header_spacing }}px;
    gap: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-featured-products-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: {{ block.settings.header_spacing_mobile }}px;
    }
  }

  .ai-featured-products-header-left-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-featured-products-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    letter-spacing: {{ block.settings.label_spacing }};
    font-weight: {{ block.settings.label_weight }};
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    margin: 0 0 {{ block.settings.label_margin }}px;
  }

  .ai-featured-products-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin }}px;
    line-height: 1.2;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
  }

  @media screen and (max-width: 749px) {
    .ai-featured-products-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }
  }

  .ai-featured-products-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-featured-products-shop-all-{{ ai_gen_id }} {
    text-decoration: none;
    color: {{ block.settings.shop_all_color }};
    font-size: {{ block.settings.shop_all_size }}px;
    letter-spacing: {{ block.settings.shop_all_spacing }};
    text-transform: uppercase;
    font-weight: {{ block.settings.shop_all_weight }};
    position: relative;
    display: inline-block;
    padding-bottom: 4px;
  }

  .ai-featured-products-shop-all-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.shop_all_color }};
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .ai-featured-products-shop-all-{{ ai_gen_id }}:hover::after {
    transform: scaleX(1.2);
  }

  .ai-featured-products-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (max-width: 989px) and (min-width: 750px) {
    .ai-featured-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-featured-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }
  }

  .ai-product-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: visible;
    transition: transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1), box-shadow 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
    position: relative;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
  }

  .ai-product-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
    background: {{ block.settings.image_background }};
    overflow: hidden;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card-image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_zoom_scale }});
  }

  .ai-product-card-image-secondary-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card-image-secondary-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-sale-badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_top }}px;
    left: {{ block.settings.badge_left }}px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_color }};
    border-radius: {{ block.settings.badge_radius }}px;
    height: {{ block.settings.badge_height }}px;
    padding: 0 {{ block.settings.badge_padding }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    z-index: 2;
  }

  .ai-quick-add-wrapper-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.quick_add_padding }}px;
    transform: translateY(100%);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-quick-add-wrapper-{{ ai_gen_id }} {
    transform: translateY(0);
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-quick-add-wrapper-{{ ai_gen_id }} {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .ai-quick-add-button-{{ ai_gen_id }} {
    width: 100%;
    background: {{ block.settings.quick_add_background }};
    color: {{ block.settings.quick_add_color }};
    border: none;
    border-radius: {{ block.settings.quick_add_radius }}px;
    height: {{ block.settings.quick_add_height }}px;
    font-size: {{ block.settings.quick_add_font_size }}px;
    font-weight: {{ block.settings.quick_add_font_weight }};
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .ai-quick-add-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.quick_add_hover_background }};
  }

  .ai-product-card-info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_info_padding }}px 0 0;
  }

  .ai-product-brand-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_size }}px;
    color: {{ block.settings.brand_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.brand_spacing }};
    margin: 0 0 {{ block.settings.brand_margin }}px;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin }}px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-product-title-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
  }

  .ai-product-price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.price_gap }}px;
    margin-bottom: {{ block.settings.price_margin }}px;
  }

  .ai-product-price-current-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    color: {{ block.settings.price_color }};
  }

  .ai-product-price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-product-swatches-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.swatch_gap }}px;
    margin-bottom: {{ block.settings.swatch_margin }}px;
  }

  .ai-product-swatch-{{ ai_gen_id }} {
    width: {{ block.settings.swatch_size }}px;
    height: {{ block.settings.swatch_size }}px;
    border-radius: 50%;
    border: 1px solid {{ block.settings.swatch_border_color }};
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .ai-product-swatch-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
  }

  .ai-product-swatch-active-{{ ai_gen_id }} {
    border: 2px solid {{ block.settings.swatch_active_border }};
  }

  .ai-product-sizes-{{ ai_gen_id }} {
    font-size: {{ block.settings.size_font_size }}px;
    color: {{ block.settings.size_color }};
    margin: 0;
  }

  .ai-product-placeholder-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-placeholder-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
{% endstyle %}

<editorial-featured-products-{{ ai_gen_id }} class="ai-featured-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-products-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-featured-products-header-{{ ai_gen_id }}">
        <div class="ai-featured-products-header-left-{{ ai_gen_id }}">
          {% if block.settings.label != blank %}
            <div class="ai-featured-products-label-{{ ai_gen_id }}">{{ block.settings.label }}</div>
          {% endif %}
          {% if block.settings.heading != blank %}
            <h2 class="ai-featured-products-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.subtext != blank %}
            <p class="ai-featured-products-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
          {% endif %}
        </div>
        {% if block.settings.show_shop_all and block.settings.collection != blank %}
          <a href="{{ block.settings.collection.url }}" class="ai-featured-products-shop-all-{{ ai_gen_id }}">
            {{ block.settings.shop_all_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-featured-products-grid-{{ ai_gen_id }}">
      {% if block.settings.collection != blank %}
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-product-card-{{ ai_gen_id }}">
            <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
              {% if product.compare_at_price > product.price %}
                {% assign discount_percent = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                <div class="ai-sale-badge-{{ ai_gen_id }}">-{{ discount_percent }}%</div>
              {% endif %}

              <a href="{{ product.url }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-product-card-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | divided_by: product.featured_image.aspect_ratio | round }}"
                  >
                {% else %}
                  <div class="ai-product-placeholder-wrapper-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if product.images[1] and block.settings.show_second_image %}
                  <img
                    src="{{ product.images[1] | image_url: width: 800 }}"
                    alt="{{ product.images[1].alt | escape }}"
                    class="ai-product-card-image-secondary-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | divided_by: product.images[1].aspect_ratio | round }}"
                  >
                {% endif %}
              </a>

              {% if block.settings.show_quick_add %}
                <div class="ai-quick-add-wrapper-{{ ai_gen_id }}">
                  {% if product.available %}
                    <button class="ai-quick-add-button-{{ ai_gen_id }}" data-product-id="{{ product.id }}">
                      {{ block.settings.quick_add_text }}
                    </button>
                  {% else %}
                    <button class="ai-quick-add-button-{{ ai_gen_id }}" disabled>
                      {{ block.settings.sold_out_text }}
                    </button>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            <div class="ai-product-card-info-{{ ai_gen_id }}">
              {% if block.settings.show_vendor and product.vendor != blank %}
                <div class="ai-product-brand-{{ ai_gen_id }}">{{ product.vendor }}</div>
              {% endif %}

              <h3 class="ai-product-title-{{ ai_gen_id }}">
                <a href="{{ product.url }}" class="ai-product-title-link-{{ ai_gen_id }}">
                  {{ product.title }}
                </a>
              </h3>

              <div class="ai-product-price-{{ ai_gen_id }}">
                <span class="ai-product-price-current-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </span>
                {% if product.compare_at_price > product.price %}
                  <span class="ai-product-price-compare-{{ ai_gen_id }}">
                    {{ product.compare_at_price | money }}
                  </span>
                {% endif %}
              </div>

              {% if block.settings.show_color_swatches %}
                {% assign color_option = product.options_with_values | where: 'name', 'Color' | first %}
                {% if color_option %}
                  <div class="ai-product-swatches-{{ ai_gen_id }}">
                    {% for value in color_option.values limit: 5 %}
                      {% assign color_name = value | handleize %}
                      <div
                        class="ai-product-swatch-{{ ai_gen_id }} {% if forloop.first %}ai-product-swatch-active-{{ ai_gen_id }}{% endif %}"
                        style="background-color: {{ value | handleize }};"
                        title="{{ value }}"
                      ></div>
                    {% endfor %}
                  </div>
                {% endif %}
              {% endif %}

              {% if block.settings.show_sizes %}
                {% assign size_option = product.options_with_values | where: 'name', 'Size' | first %}
                {% if size_option %}
                  <p class="ai-product-sizes-{{ ai_gen_id }}">
                    {% for value in size_option.values %}
                      {{ value }}{% unless forloop.last %} · {% endunless %}
                    {% endfor %}
                  </p>
                {% endif %}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..block.settings.products_to_show) %}
          <div class="ai-product-card-{{ ai_gen_id }}">
            <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
              <div class="ai-product-placeholder-wrapper-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            </div>
            <div class="ai-product-card-info-{{ ai_gen_id }}">
              <div class="ai-product-brand-{{ ai_gen_id }}">Brand Name</div>
              <h3 class="ai-product-title-{{ ai_gen_id }}">Product Title</h3>
              <div class="ai-product-price-{{ ai_gen_id }}">
                <span class="ai-product-price-current-{{ ai_gen_id }}">৳1,000</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</editorial-featured-products-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialFeaturedProducts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupQuickAdd();
      }

      setupQuickAdd() {
        const buttons = this.querySelectorAll('.ai-quick-add-button-{{ ai_gen_id }}');
        buttons.forEach(button => {
          button.addEventListener('click', (e) => {
            const productId = e.target.dataset.productId;
            if (productId) {
              this.addToCart(productId, e.target);
            }
          });
        });
      }

      addToCart(productId, button) {
        const originalText = button.textContent;
        button.textContent = 'Adding...';
        button.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: productId,
            quantity: 1
          })
        })
        .then(response => response.json())
        .then(data => {
          button.textContent = 'Added!';
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
          
          if (window.theme && window.theme.cart) {
            window.theme.cart.refresh();
          }
        })
        .catch(error => {
          button.textContent = 'Error';
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
        });
      }
    }

    customElements.define('editorial-featured-products-{{ ai_gen_id }}', EditorialFeaturedProducts{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Featured products",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "checkbox",
