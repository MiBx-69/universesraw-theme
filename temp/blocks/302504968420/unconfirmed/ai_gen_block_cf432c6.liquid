{% doc %}
  @prompt
    Create a new Shopify Featured Products section inspired by the attached reference image.
    
    The section should have a premium editorial fashion design suitable for a luxury clothing brand.
    
    Do not redesign the product cards. Use the theme's existing default product card component so all pricing, badges, variants, Quick Add, and functionality remain unchanged.
    
    Only create a new section with a modern editorial header and layout.
    
    Section Header:
    - Small uppercase label: THE EDIT
    - Large elegant serif heading: Featured Selection
    - Short description: "Handpicked pieces from our latest drop."
    - "SHOP ALL" link aligned to the right with a thin underline and subtle hover animation.
    
    Layout:
    - Featured Collection picker in the Theme Editor.
    - Desktop: 4 products per row.
    - Tablet: 3 products.
    - Mobile: 2 products.
    - Maximum width around 1400px.
    - Large spacing between the header and products.
    - Generous white space above and below the section.
    
    Design Style:
    - Luxury
    - Editorial
    - Modern
    - Minimal
    - Fashion-focused
    
    Use a clean white background, refined typography, balanced spacing, and premium alignment inspired by the attached reference image.
    
    The entire section must be fully customizable from the Shopify Theme Editor, including:
    - Featured Collection
    - Heading
    - Subheading
    - Eyebrow text
    - Shop All text
    - Shop All link
    - Products to show
    - Top and bottom spacing
    
    Keep the section lightweight, responsive, accessible, and compatible with Online Store 2.0.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-products-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.spacing_top }}px;
    padding-bottom: {{ block.settings.spacing_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-featured-products-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-featured-products-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: {{ block.settings.header_spacing }}px;
    gap: 20px;
  }

  .ai-featured-products-header-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-featured-products-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: 12px;
    font-weight: 500;
  }

  .ai-featured-products-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
    font-weight: 400;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-style: {{ block.settings.heading_font.style }};
  }

  .ai-featured-products-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.description_color }};
    max-width: 600px;
  }

  .ai-featured-products-shop-all-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.shop_all_size }}px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: {{ block.settings.shop_all_color }};
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    transition: color 0.3s ease;
    white-space: nowrap;
  }

  .ai-featured-products-shop-all-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.shop_all_color }};
    transition: transform 0.3s ease;
    transform-origin: left;
  }

  .ai-featured-products-shop-all-{{ ai_gen_id }}:hover {
    color: {{ block.settings.shop_all_hover_color }};
  }

  .ai-featured-products-shop-all-{{ ai_gen_id }}:hover::after {
    transform: scaleX(0);
    transform-origin: right;
  }

  .ai-featured-products-shop-all-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-featured-products-shop-all-{{ ai_gen_id }}:hover .ai-featured-products-shop-all-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-featured-products-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (max-width: 989px) {
    .ai-featured-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_tablet }}, 1fr);
    }

    .ai-featured-products-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-featured-products-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 40px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-featured-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }

    .ai-featured-products-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.5);
    }

    .ai-featured-products-eyebrow-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.eyebrow_size }}px * 0.9);
    }

    .ai-featured-products-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }

    .ai-featured-products-container-{{ ai_gen_id }} {
      padding: 0 16px;
    }
  }
{% endstyle %}

<featured-products-{{ ai_gen_id }} class="ai-featured-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-products-container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank or block.settings.heading != blank or block.settings.description != blank or block.settings.shop_all_text != blank %}
      <div class="ai-featured-products-header-{{ ai_gen_id }}">
        <div class="ai-featured-products-header-content-{{ ai_gen_id }}">
          {% if block.settings.eyebrow != blank %}
            <div class="ai-featured-products-eyebrow-{{ ai_gen_id }}">
              {{ block.settings.eyebrow }}
            </div>
          {% endif %}

          {% if block.settings.heading != blank %}
            <h2 class="ai-featured-products-heading-{{ ai_gen_id }}">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.description != blank %}
            <div class="ai-featured-products-description-{{ ai_gen_id }}">
              {{ block.settings.description }}
            </div>
          {% endif %}
        </div>

        {% if block.settings.shop_all_text != blank and block.settings.shop_all_link != blank %}
          <a href="{{ block.settings.shop_all_link }}" class="ai-featured-products-shop-all-{{ ai_gen_id }}">
            {{ block.settings.shop_all_text }}
            <svg class="ai-featured-products-shop-all-arrow-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 8H15M15 8L8 1M15 8L8 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-featured-products-grid-{{ ai_gen_id }}">
        {% assign products_to_show = block.settings.products_to_show %}
        {% for product in block.settings.collection.products limit: products_to_show %}
          {% render 'card-product', card_product: product, show_vendor: false %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-featured-products-grid-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% render 'card-product', card_product: blank, show_vendor: false %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</featured-products-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedProducts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeAccessibility();
      }

      initializeAccessibility() {
        const heading = this.querySelector('.ai-featured-products-heading-{{ ai_gen_id }}');
        const grid = this.querySelector('.ai-featured-products-grid-{{ ai_gen_id }}');
        
        if (heading && grid) {
          const headingId = 'featured-products-heading-{{ ai_gen_id }}';
          heading.id = headingId;
          grid.setAttribute('aria-labelledby', headingId);
        }
      }
    }

    customElements.define('featured-products-{{ ai_gen_id }}', FeaturedProducts{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Featured products",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "header",
      "content": "Header content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "THE EDIT"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Selection"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "Description",
      "default": "Handpicked pieces from our latest drop."
    },
    {
      "type": "text",
      "id": "shop_all_text",
      "label": "Shop all text",
      "default": "SHOP ALL"
    },
    {
      "type": "url",
      "id": "shop_all_link",
      "label": "Shop all link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Container width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "min": 2,
      "max": 6,
