      "default": 30
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Header spacing",
      "default": 60
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
