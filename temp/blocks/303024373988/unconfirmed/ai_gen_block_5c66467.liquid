{% doc %}
  @prompt
    Create a luxury editorial footer section for a premium fashion and streetwear brand called "Universes". Design: deep black background (#0A0A0A), off-white/cream text (#F5F0EB), gold accent color (#C9A96E) for links on hover and dividers. Layout: multi-column with brand logo/name on the left, navigation link groups in the middle (Shop, Help, Legal), and a newsletter email signup on the right. Include a short brand tagline below the logo (e.g. "Wear Your Universe"). Bottom bar with copyright text and payment icons. Social media icons (Instagram, TikTok, Facebook) in minimal outline style. Generous padding, uppercase spaced-out headings for each column, clean sans-serif body text. Fully customizable via theme editor settings (links, tagline, newsletter heading, social URLs).
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-footer-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_top }}px 0 0;
    width: 100%;
  }

  .ai-luxury-footer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-luxury-footer-main-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    padding-bottom: {{ block.settings.main_padding_bottom }}px;
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-luxury-footer-brand-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-luxury-footer-logo-{{ ai_gen_id }} {
    font-size: {{ block.settings.logo_size }}px;
    font-weight: 700;
    letter-spacing: {{ block.settings.logo_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-luxury-footer-tagline-{{ ai_gen_id }} {
    font-size: {{ block.settings.tagline_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
    font-style: italic;
  }

  .ai-luxury-footer-nav-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-luxury-footer-nav-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-luxury-footer-nav-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
  }

  .ai-luxury-footer-nav-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-luxury-footer-nav-link-{{ ai_gen_id }} {
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    transition: color 0.3s ease;
    display: inline-block;
  }

  .ai-luxury-footer-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.accent_color }};
  }

  .ai-luxury-footer-newsletter-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-luxury-footer-newsletter-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-luxury-footer-newsletter-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-luxury-footer-newsletter-form-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-luxury-footer-newsletter-input-{{ ai_gen_id }} {
    flex: 1;
    padding: 12px 16px;
    background-color: transparent;
    border: 1px solid {{ block.settings.text_color }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.link_size }}px;
    border-radius: 0;
  }

  .ai-luxury-footer-newsletter-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  .ai-luxury-footer-newsletter-button-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.text_color }};
    color: {{ block.settings.background_color }};
    border: none;
    font-size: {{ block.settings.link_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-luxury-footer-newsletter-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
  }

  .ai-luxury-footer-newsletter-success-{{ ai_gen_id }},
  .ai-luxury-footer-newsletter-error-{{ ai_gen_id }} {
    font-size: {{ block.settings.link_size }}px;
    margin-top: 8px;
  }

  .ai-luxury-footer-newsletter-success-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
  }

  .ai-luxury-footer-newsletter-error-{{ ai_gen_id }} {
    color: #ff6b6b;
  }

  .ai-luxury-footer-bottom-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.bottom_padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-luxury-footer-copyright-{{ ai_gen_id }} {
    font-size: {{ block.settings.bottom_text_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  .ai-luxury-footer-social-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .ai-luxury-footer-social-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
  }

  .ai-luxury-footer-social-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.accent_color }};
  }

  .ai-luxury-footer-social-icon-{{ ai_gen_id }} {
    width: {{ block.settings.social_icon_size }}px;
    height: {{ block.settings.social_icon_size }}px;
  }

  .ai-luxury-footer-payment-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .ai-luxury-footer-payment-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.bottom_text_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  .ai-luxury-footer-payment-icons-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-luxury-footer-payment-icon-{{ ai_gen_id }} {
    width: 40px;
    height: 26px;
    background-color: {{ block.settings.text_color }};
    border-radius: 4px;
    opacity: 0.7;
  }

  @media screen and (max-width: 989px) {
    .ai-luxury-footer-main-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-luxury-footer-nav-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }

    .ai-luxury-footer-bottom-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 24px;
      text-align: center;
    }

    .ai-luxury-footer-social-{{ ai_gen_id }} {
      order: -1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-footer-nav-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-luxury-footer-newsletter-form-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-luxury-footer-newsletter-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<luxury-footer-{{ ai_gen_id }} class="ai-luxury-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-footer-container-{{ ai_gen_id }}">
    <div class="ai-luxury-footer-main-{{ ai_gen_id }}">
      <div class="ai-luxury-footer-brand-{{ ai_gen_id }}">
        {% if block.settings.logo_text != blank %}
          <h2 class="ai-luxury-footer-logo-{{ ai_gen_id }}">{{ block.settings.logo_text }}</h2>
        {% endif %}
        {% if block.settings.tagline != blank %}
          <p class="ai-luxury-footer-tagline-{{ ai_gen_id }}">{{ block.settings.tagline }}</p>
        {% endif %}
      </div>

      <div class="ai-luxury-footer-nav-{{ ai_gen_id }}">
