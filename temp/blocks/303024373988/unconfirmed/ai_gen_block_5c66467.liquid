      </div>

      <div class="ai-luxury-footer-newsletter-{{ ai_gen_id }}">
        {% if block.settings.newsletter_heading != blank %}
          <h3 class="ai-luxury-footer-newsletter-heading-{{ ai_gen_id }}">{{ block.settings.newsletter_heading }}</h3>
        {% endif %}
        {% if block.settings.newsletter_text != blank %}
          <p class="ai-luxury-footer-newsletter-text-{{ ai_gen_id }}">{{ block.settings.newsletter_text }}</p>
        {% endif %}
        {% form 'customer', class: 'ai-luxury-footer-newsletter-form-{{ ai_gen_id }}' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            class="ai-luxury-footer-newsletter-input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.newsletter_placeholder }}"
            aria-label="Email address"
            required
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-luxury-footer-newsletter-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-luxury-footer-newsletter-success-{{ ai_gen_id }}"
            {% endif %}
          >
          <button type="submit" class="ai-luxury-footer-newsletter-button-{{ ai_gen_id }}">
            {{ block.settings.newsletter_button_text }}
          </button>
        {% endform %}
        {% if form.posted_successfully? %}
          <p id="ai-luxury-footer-newsletter-success-{{ ai_gen_id }}" class="ai-luxury-footer-newsletter-success-{{ ai_gen_id }}">
            {{ block.settings.newsletter_success_message }}
