            <h3 class="ai-luxury-footer-nav-heading-{{ ai_gen_id }}">{{ block.settings.nav_heading_1 }}</h3>
          {% endif %}
          <ul class="ai-luxury-footer-nav-list-{{ ai_gen_id }}">
            {% if block.settings.nav_link_1_text != blank and block.settings.nav_link_1_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_1_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_1_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.nav_link_2_text != blank and block.settings.nav_link_2_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_2_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_2_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.nav_link_3_text != blank and block.settings.nav_link_3_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_3_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_3_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.nav_link_4_text != blank and block.settings.nav_link_4_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_4_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_4_text }}
                </a>
              </li>
            {% endif %}
          </ul>
        </div>

        <div class="ai-luxury-footer-nav-column-{{ ai_gen_id }}">
          {% if block.settings.nav_heading_2 != blank %}
            <h3 class="ai-luxury-footer-nav-heading-{{ ai_gen_id }}">{{ block.settings.nav_heading_2 }}</h3>
          {% endif %}
          <ul class="ai-luxury-footer-nav-list-{{ ai_gen_id }}">
            {% if block.settings.nav_link_5_text != blank and block.settings.nav_link_5_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_5_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_5_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.nav_link_6_text != blank and block.settings.nav_link_6_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_6_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_6_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.nav_link_7_text != blank and block.settings.nav_link_7_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_7_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_7_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.nav_link_8_text != blank and block.settings.nav_link_8_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_8_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_8_text }}
                </a>
              </li>
            {% endif %}
          </ul>
        </div>

        <div class="ai-luxury-footer-nav-column-{{ ai_gen_id }}">
          {% if block.settings.nav_heading_3 != blank %}
            <h3 class="ai-luxury-footer-nav-heading-{{ ai_gen_id }}">{{ block.settings.nav_heading_3 }}</h3>
          {% endif %}
          <ul class="ai-luxury-footer-nav-list-{{ ai_gen_id }}">
            {% if block.settings.nav_link_9_text != blank and block.settings.nav_link_9_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_9_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_9_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.nav_link_10_text != blank and block.settings.nav_link_10_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_10_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_10_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.nav_link_11_text != blank and block.settings.nav_link_11_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_11_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
                  {{ block.settings.nav_link_11_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.nav_link_12_text != blank and block.settings.nav_link_12_url != blank %}
              <li>
                <a href="{{ block.settings.nav_link_12_url }}" class="ai-luxury-footer-nav-link-{{ ai_gen_id }}">
