</luxury-footer-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryFooter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('.ai-luxury-footer-newsletter-form-{{ ai_gen_id }}');
        if (this.form) {
          this.setupFormValidation();
        }
      }

      setupFormValidation() {
        const emailInput = this.form.querySelector('input[type="email"]');
        if (emailInput) {
          emailInput.addEventListener('invalid', function(event) {
            event.preventDefault();
            emailInput.setAttribute('aria-invalid', 'true');
          });

          emailInput.addEventListener('input', function() {
            if (emailInput.validity.valid) {
              emailInput.removeAttribute('aria-invalid');
            }
          });
        }
      }
    }

    customElements.define('luxury-footer-{{ ai_gen_id }}', LuxuryFooter{{ ai_gen_id }});
  })();
</script>

