        {% endif %}
        {% if form.errors %}
          <p id="ai-luxury-footer-newsletter-error-{{ ai_gen_id }}" class="ai-luxury-footer-newsletter-error-{{ ai_gen_id }}">
            {{ form.errors.messages.email }}
          </p>
        {% endif %}
