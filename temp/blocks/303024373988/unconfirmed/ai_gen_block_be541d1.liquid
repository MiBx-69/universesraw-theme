{% doc %}
  @prompt
    Create a full-bleed cinematic hero section for a luxury premium fashion and streetwear brand. Features: full viewport-height background image or video, a subtle dark gradient overlay for text legibility, centered or left-aligned editorial headline in a large luxury serif font, a short subheading in a clean sans-serif, and a minimal ghost/outlined CTA button with sharp corners. Include a smooth fade-in entrance animation on page load. All content (heading, subheading, button text, button link, background image/video) should be customizable via theme editor settings. Mobile-optimized with adjusted font sizes and padding.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cinematic-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: block;
  }

  .ai-cinematic-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-cinematic-hero-background-{{ ai_gen_id }} img,
  .ai-cinematic-hero-background-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-cinematic-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-cinematic-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-cinematic-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-cinematic-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity_top }}),
      rgba(0, 0, 0, {{ block.settings.overlay_opacity_bottom }})
    );
    z-index: 2;
  }

  .ai-cinematic-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    flex-direction: column;
    {% if block.settings.text_alignment == 'left' %}
      align-items: flex-start;
      text-align: left;
    {% elsif block.settings.text_alignment == 'center' %}
      align-items: center;
      text-align: center;
    {% else %}
      align-items: flex-end;
      text-align: right;
    {% endif %}
    justify-content: center;
    padding: 40px;
    max-width: {{ block.settings.content_max_width }}px;
    {% if block.settings.text_alignment == 'left' %}
      margin-left: 0;
      margin-right: auto;
    {% elsif block.settings.text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% else %}
      margin-left: auto;
      margin-right: 0;
    {% endif %}
    opacity: 0;
    transform: translateY(30px);
  }

  .ai-cinematic-hero-{{ ai_gen_id }}.ai-cinematic-hero-loaded-{{ ai_gen_id }} .ai-cinematic-hero-content-{{ ai_gen_id }} {
    animation: ai-cinematic-hero-fade-in-{{ ai_gen_id }} 1.2s ease-out forwards;
  }

  @keyframes ai-cinematic-hero-fade-in-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-cinematic-hero-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    letter-spacing: -0.02em;
  }

  .ai-cinematic-hero-subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheading_font.family }}, {{ block.settings.subheading_font.fallback_families }};
    font-weight: {{ block.settings.subheading_font.weight }};
    font-style: {{ block.settings.subheading_font.style }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px 0;
    opacity: 0.9;
  }

  .ai-cinematic-hero-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: 0;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-cinematic-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-cinematic-hero-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}vh;
    }

    .ai-cinematic-hero-content-{{ ai_gen_id }} {
      padding: 20px;
      max-width: 100%;
    }

    .ai-cinematic-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_spacing_mobile }}px;
    }

    .ai-cinematic-hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
      margin-bottom: {{ block.settings.subheading_spacing_mobile }}px;
    }

    .ai-cinematic-hero-button-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_vertical_mobile }}px {{ block.settings.button_padding_horizontal_mobile }}px;
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }
  }
{% endstyle %}

<cinematic-hero-{{ ai_gen_id }}
  class="ai-cinematic-hero-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-cinematic-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_video != blank %}
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      >
        <source src="{{ block.settings.background_video }}" type="video/mp4">
      </video>
    {% elsif block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        srcset="{{ block.settings.background_image | image_url: width: 750 }} 750w,
                {{ block.settings.background_image | image_url: width: 1500 }} 1500w,
                {{ block.settings.background_image | image_url: width: 2000 }} 2000w"
        sizes="100vw"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="eager"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-cinematic-hero-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-cinematic-hero-empty-state-{{ ai_gen_id }}">
          Add a background image or video
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-cinematic-hero-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-cinematic-hero-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h1 class="ai-cinematic-hero-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <p class="ai-cinematic-hero-subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </p>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-cinematic-hero-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</cinematic-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class CinematicHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        setTimeout(() => {
          this.classList.add('ai-cinematic-hero-loaded-{{ ai_gen_id }}');
        }, 100);
      }
    }

    customElements.define('cinematic-hero-{{ ai_gen_id }}', CinematicHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Cinematic hero",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "url",
      "id": "background_video",
      "label": "Background video URL",
      "info": "MP4 format recommended. Video will override image if both are set."
    },
    {
      "type": "range",
      "id": "overlay_opacity_top",
      "label": "Overlay opacity (top)",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "range",
      "id": "overlay_opacity_bottom",
      "label": "Overlay opacity (bottom)",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.6
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury Redefined"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover the new collection of premium streetwear"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Desktop size",
      "min": 30,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Mobile size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Desktop spacing",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_spacing_mobile",
      "label": "Mobile spacing",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Subheading style"
    },
    {
      "type": "font_picker",
      "id": "subheading_font",
      "label": "Subheading font",
      "default": "sans-serif"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Desktop size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "subheading_size_mobile",
      "label": "Mobile size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "subheading_spacing",
      "label": "Desktop spacing",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheading_spacing_mobile",
      "label": "Mobile spacing",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Desktop font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_font_size_mobile",
      "label": "Mobile font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Desktop vertical padding",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Desktop horizontal padding",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "button_padding_vertical_mobile",
      "label": "Mobile vertical padding",
      "min": 6,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_horizontal_mobile",
      "label": "Mobile horizontal padding",
      "min": 15,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    }
  ],
  "presets": [
    {
      "name": "Cinematic hero"
    }
  ]
}
{% endschema %}
