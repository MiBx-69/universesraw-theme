{% doc %}
  @prompt
    Redesign the existing Featured Products section using the attached reference image as the design inspiration.
    
    Do not create a new section. Upgrade the current Featured Products section and its existing product cards while keeping all Shopify functionality working.
    
    Design Style:
    - Luxury, modern, editorial, minimalist
    - Inspired by premium fashion brands like COS, ARKET, Represent, and Fear of God
    - Large white space
    - Premium typography
    - Clean layout
    - Mobile-first
    
    Section Header:
    - Small uppercase label: THE EDIT
    - Large serif heading: Featured Selection
    - Short description below
    - SHOP ALL link aligned to the right with an animated underline
    
    Product Cards:
    - Large rounded image container with a light gray background
    - Rounded corners (18px)
    - No borders
    - Elegant spacing
    - Premium typography
    - Large product image
    
    Hover Effects:
    - Slight card lift
    - Product image zoom
    - Show second product image if available
    - Smooth transitions
    
    Quick Add:
    - Hide the Quick Add button by default.
    - When the customer hovers over the product image on desktop, smoothly fade and slide the Quick Add button up from the bottom of the image.
    - Hide it again when the mouse leaves.
    - On mobile, keep the Quick Add button visible.
    - Use the existing Shopify AJAX Add to Cart functionality.
    
    Quick Add Button Style:
    - Black pill-shaped button
    - White shopping bag icon
    - White uppercase text: QUICK ADD
    - Fully rounded
    - Premium hover animation
    
    Sale Badge:
    - Show a rounded red discount badge in the top-left corner.
    - Automatically calculate the percentage using Compare-at Price.
    - Hide the badge if the product is not on sale.
    
    Wishlist:
    - Add a floating heart button in the top-right corner.
    - White circular background with a soft shadow.
    - Change to black on hover.
    
    Product Information:
    - Small uppercase vendor name
    - Elegant two-line product title
    - Bold current price
    - Gray compare-at price with strikethrough
    - Display available color swatches
    - Display available sizes below
    
    Layout:
    - 4 columns on desktop
    - 3 columns on tablet
    - 2 columns on mobile
    
    Keep everything dynamic using Shopify product data, variants, pricing, images, and Theme Editor settings.
    
    The final result should closely match the attached reference image while preserving all existing functionality.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-products-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-featured-products__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-featured-products__header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: {{ block.settings.header_spacing }}px;
    gap: 20px;
  }

  .ai-featured-products__header-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-featured-products__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.label_color }};
    margin: 0 0 12px 0;
    font-weight: 500;
  }

  .ai-featured-products__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .ai-featured-products__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    max-width: 600px;
    line-height: 1.6;
  }

  .ai-featured-products__shop-all-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 500;
    position: relative;
    padding-bottom: 4px;
  }

  .ai-featured-products__shop-all-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: {{ block.settings.link_color }};
    transition: width 0.3s ease;
  }

  .ai-featured-products__shop-all-{{ ai_gen_id }}:hover::after {
    width: 100%;
  }

  .ai-featured-products__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: relative;
    transition: transform 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
  }

  .ai-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.image_background }};
    border-radius: {{ block.settings.image_radius }}px;
    overflow: hidden;
    margin-bottom: 16px;
    aspect-ratio: {{ block.settings.image_ratio }};
  }

  .ai-product-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-product-card__image-secondary-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card__image-secondary-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-product-card__badges-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-card__badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 6px 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_color }};
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: {{ block.settings.badge_radius }}px;
  }

  .ai-product-card__wishlist-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 2;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.wishlist_background }};
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-product-card__wishlist-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.wishlist_hover_background }};
    transform: scale(1.1);
  }

  .ai-product-card__wishlist-icon-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
    stroke: {{ block.settings.wishlist_icon_color }};
    fill: none;
    stroke-width: 2;
  }

  .ai-product-card__wishlist-{{ ai_gen_id }}:hover .ai-product-card__wishlist-icon-{{ ai_gen_id }} {
    fill: {{ block.settings.wishlist_icon_color }};
  }

  .ai-product-card__quick-add-wrapper-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card__quick-add-wrapper-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-product-card__quick-add-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.quick_add_background }};
    color: {{ block.settings.quick_add_color }};
    border: none;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.3s ease;
  }

  .ai-product-card__quick-add-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.quick_add_hover_background }};
    transform: scale(1.02);
  }

  .ai-product-card__quick-add-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
  }

  .ai-product-card__info-{{ ai_gen_id }} {
    padding: 0 4px;
  }

  .ai-product-card__vendor-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ block.settings.vendor_color }};
    margin: 0 0 8px 0;
    font-weight: 500;
  }

  .ai-product-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 12px 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-product-card__title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-card__title-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_color }};
  }

  .ai-product-card__price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-product-card__price-current-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 700;
    color: {{ block.settings.price_color }};
  }

  .ai-product-card__price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | minus: 2 }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-product-card__price-sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-product-card__swatches-{{ ai_gen_id }} {
    display: flex;
    gap: 6px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .ai-product-card__swatch-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid {{ block.settings.swatch_border_color }};
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .ai-product-card__swatch-{{ ai_gen_id }}:hover {
    transform: scale(1.15);
    border-color: {{ block.settings.swatch_hover_border }};
  }

  .ai-product-card__sizes-{{ ai_gen_id }} {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .ai-product-card__size-{{ ai_gen_id }} {
    font-size: 11px;
    padding: 4px 10px;
    border: 1px solid {{ block.settings.size_border_color }};
    border-radius: 4px;
    color: {{ block.settings.size_color }};
    background-color: transparent;
    transition: all 0.2s ease;
  }

  .ai-product-card__size-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.size_hover_background }};
    border-color: {{ block.settings.size_hover_border }};
  }

  @media screen and (max-width: 989px) {
    .ai-featured-products__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-featured-products__header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .ai-featured-products__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-featured-products__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-product-card__quick-add-wrapper-{{ ai_gen_id }} {
      opacity: 1;
      transform: translateY(0);
    }

    .ai-featured-products__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.5 }}px;
    }

    .ai-featured-products__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | minus: 1 }}px;
    }
  }
{% endstyle %}

<featured-products-{{ ai_gen_id }} class="ai-featured-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-products__container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-featured-products__header-{{ ai_gen_id }}">
        <div class="ai-featured-products__header-content-{{ ai_gen_id }}">
          {% if block.settings.label != blank %}
            <p class="ai-featured-products__label-{{ ai_gen_id }}">{{ block.settings.label }}</p>
          {% endif %}
          {% if block.settings.heading != blank %}
            <h2 class="ai-featured-products__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="ai-featured-products__description-{{ ai_gen_id }}">{{ block.settings.description }}</p>
          {% endif %}
        </div>
        {% if block.settings.show_shop_all and block.settings.shop_all_url != blank %}
          <a href="{{ block.settings.shop_all_url }}" class="ai-featured-products__shop-all-{{ ai_gen_id }}">
            {{ block.settings.shop_all_text }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 12l4-4-4-4"/>
            </svg>
          </a>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-featured-products__grid-{{ ai_gen_id }}">
      {% if block.settings.collection != blank %}
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-product-card-{{ ai_gen_id }}">
            <div class="ai-product-card__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-product-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | divided_by: product.featured_image.aspect_ratio | round }}"
                >
              {% endif %}

              {% if product.images[1] and block.settings.show_second_image %}
                <img
                  src="{{ product.images[1] | image_url: width: 800 }}"
                  alt="{{ product.images[1].alt | escape }}"
                  class="ai-product-card__image-secondary-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | divided_by: product.images[1].aspect_ratio | round }}"
                >
              {% endif %}

              <div class="ai-product-card__badges-{{ ai_gen_id }}">
                {% if product.compare_at_price > product.price and block.settings.show_sale_badge %}
                  {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                  <span class="ai-product-card__badge-{{ ai_gen_id }}">-{{ discount }}%</span>
                {% endif %}
              </div>

              {% if block.settings.show_wishlist %}
                <button class="ai-product-card__wishlist-{{ ai_gen_id }}" aria-label="Add to wishlist">
                  <svg class="ai-product-card__wishlist-icon-{{ ai_gen_id }}" viewBox="0 0 24 24">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                </button>
              {% endif %}

              {% if block.settings.show_quick_add %}
                <div class="ai-product-card__quick-add-wrapper-{{ ai_gen_id }}">
                  <button
                    class="ai-product-card__quick-add-{{ ai_gen_id }}"
                    data-product-id="{{ product.id }}"
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                  >
                    <svg class="ai-product-card__quick-add-icon-{{ ai_gen_id }}" viewBox="0 0 24 24">
                      <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                      <line x1="3" y1="6" x2="21" y2="6"/>
                      <path d="M16 10a4 4 0 0 1-8 0"/>
                    </svg>
                    {{ block.settings.quick_add_text }}
                  </button>
                </div>
              {% endif %}
            </div>

            <div class="ai-product-card__info-{{ ai_gen_id }}">
              {% if block.settings.show_vendor and product.vendor != blank %}
                <p class="ai-product-card__vendor-{{ ai_gen_id }}">{{ product.vendor }}</p>
              {% endif %}

              <h3 class="ai-product-card__title-{{ ai_gen_id }}">
                <a href="{{ product.url }}" class="ai-product-card__title-link-{{ ai_gen_id }}">
                  {{ product.title }}
                </a>
              </h3>

              <div class="ai-product-card__price-{{ ai_gen_id }}">
                <span class="ai-product-card__price-current-{{ ai_gen_id }} {% if product.compare_at_price > product.price %}ai-product-card__price-sale-{{ ai_gen_id }}{% endif %}">
                  {{ product.price | money }}
                </span>
                {% if product.compare_at_price > product.price %}
                  <span class="ai-product-card__price-compare-{{ ai_gen_id }}">
                    {{ product.compare_at_price | money }}
                  </span>
                {% endif %}
              </div>

              {% if block.settings.show_color_swatches %}
                {% assign color_option = product.options_with_values | where: 'name', 'Color' | first %}
                {% if color_option %}
                  <div class="ai-product-card__swatches-{{ ai_gen_id }}">
                    {% for value in color_option.values limit: 5 %}
                      {% assign color_value = value | downcase | replace: ' ', '-' %}
                      <span
                        class="ai-product-card__swatch-{{ ai_gen_id }}"
                        style="background-color: {{ color_value }};"
                        title="{{ value }}"
                      ></span>
                    {% endfor %}
                  </div>
                {% endif %}
              {% endif %}

              {% if block.settings.show_sizes %}
                {% assign size_option = product.options_with_values | where: 'name', 'Size' | first %}
                {% if size_option %}
                  <div class="ai-product-card__sizes-{{ ai_gen_id }}">
                    {% for value in size_option.values limit: 6 %}
                      <span class="ai-product-card__size-{{ ai_gen_id }}">{{ value }}</span>
                    {% endfor %}
                  </div>
                {% endif %}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..block.settings.products_to_show) %}
          <div class="ai-product-card-{{ ai_gen_id }}">
            <div class="ai-product-card__image-wrapper-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
            <div class="ai-product-card__info-{{ ai_gen_id }}">
              <p class="ai-product-card__vendor-{{ ai_gen_id }}">Brand Name</p>
              <h3 class="ai-product-card__title-{{ ai_gen_id }}">Product Title</h3>
              <div class="ai-product-card__price-{{ ai_gen_id }}">
                <span class="ai-product-card__price-current-{{ ai_gen_id }}">৳ 2,500</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</featured-products-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedProducts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupQuickAdd();
      }

      setupQuickAdd() {
        const quickAddButtons = this.querySelectorAll('.ai-product-card__quick-add-{{ ai_gen_id }}');

        quickAddButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const variantId = button.dataset.variantId;
            this.addToCart(variantId, button);
          });
        });
      }

      addToCart(variantId, button) {
        const originalText = button.innerHTML;
        button.innerHTML = '<span>Adding...</span>';
        button.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: variantId,
            quantity: 1
          })
        })
        .then(response => response.json())
        .then(data => {
          button.innerHTML = '<span>Added ✓</span>';
          
          setTimeout(() => {
            button.innerHTML = originalText;
            button.disabled = false;
          }, 2000);

          if (window.theme && window.theme.cart) {
            window.theme.cart.refresh();
          }

          document.dispatchEvent(new CustomEvent('cart:refresh'));
        })
        .catch(error => {
          console.error('Error:', error);
          button.innerHTML = originalText;
          button.disabled = false;
        });
      }
    }

    customElements.define('featured-products-{{ ai_gen_id }}', FeaturedProducts{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Featured products",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "THE EDIT"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Selection"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Curated pieces for the modern wardrobe"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Header spacing",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Shop all link"
    },
    {
      "type": "checkbox",
      "id": "show_shop_all",
      "label": "Show shop all link",
      "default": true
