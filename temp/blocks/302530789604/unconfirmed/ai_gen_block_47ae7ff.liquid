{% doc %}
  @prompt
    creat a featured product grid for mobile first and wiht a view all nutton modenr minimalsit blakc and red color platte
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-featured-grid__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-featured-grid__header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
    gap: 16px;
  }

  .ai-featured-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_mobile }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ai-featured-grid__view-all-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    white-space: nowrap;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-featured-grid__view-all-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateX(4px);
  }

  .ai-featured-grid__view-all-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-featured-grid__view-all-{{ ai_gen_id }}:hover .ai-featured-grid__view-all-icon-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-featured-grid__products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: {{ block.settings.grid_gap_mobile }}px;
  }

  .ai-featured-grid__product-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-featured-grid__product-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-featured-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_ratio }}%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-featured-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ai-featured-grid__product-{{ ai_gen_id }}:hover .ai-featured-grid__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-featured-grid__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 6px 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: {{ block.settings.badge_border_radius }}px;
    z-index: 2;
  }

  .ai-featured-grid__info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-featured-grid__vendor-{{ ai_gen_id }} {
    font-size: 11px;
    color: {{ block.settings.vendor_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .ai-featured-grid__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size_mobile }}px;
    font-weight: 600;
    color: {{ block.settings.product_title_color }};
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-featured-grid__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .ai-featured-grid__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size_mobile }}px;
    font-weight: 700;
    color: {{ block.settings.price_color }};
  }

  .ai-featured-grid__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size_mobile | minus: 2 }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-featured-grid__sale-badge-{{ ai_gen_id }} {
    font-size: 11px;
    font-weight: 700;
    color: {{ block.settings.sale_badge_text_color }};
    background-color: {{ block.settings.sale_badge_background }};
    padding: 4px 8px;
    border-radius: 4px;
  }

  .ai-featured-grid__empty-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: #999;
  }

  .ai-featured-grid__empty-icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 16px;
    opacity: 0.3;
  }

  .ai-featured-grid__empty-text-{{ ai_gen_id }} {
    font-size: 16px;
    color: #666;
  }

  @media screen and (min-width: 750px) {
    .ai-featured-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_desktop }}px {{ block.settings.padding_horizontal_desktop }}px {{ block.settings.padding_bottom_desktop }}px;
    }

    .ai-featured-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size }}px;
    }

    .ai-featured-grid__products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.grid_gap }}px;
    }

    .ai-featured-grid__product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.product_title_size }}px;
    }

    .ai-featured-grid__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size }}px;
    }

    .ai-featured-grid__compare-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | minus: 2 }}px;
    }
  }
{% endstyle %}

<featured-product-grid-{{ ai_gen_id }} class="ai-featured-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-grid__container-{{ ai_gen_id }}">
    <div class="ai-featured-grid__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-featured-grid__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      
      {% if block.settings.view_all_url != blank and block.settings.view_all_text != blank %}
        <a href="{{ block.settings.view_all_url }}" class="ai-featured-grid__view-all-{{ ai_gen_id }}">
          {{ block.settings.view_all_text }}
          <svg class="ai-featured-grid__view-all-icon-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
    </div>

    <div class="ai-featured-grid__products-{{ ai_gen_id }}">
      {% if block.settings.product_list != blank %}
        {% for product in block.settings.product_list limit: block.settings.products_to_show %}
          <a href="{{ product.url }}" class="ai-featured-grid__product-{{ ai_gen_id }}">
            <div class="ai-featured-grid__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-featured-grid__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | times: block.settings.image_ratio | divided_by: 100 }}"
                >
              {% else %}
                <div class="ai-featured-grid__image-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block.settings.show_badge and product.tags contains block.settings.badge_tag %}
                <div class="ai-featured-grid__badge-{{ ai_gen_id }}">
                  {{ block.settings.badge_text }}
                </div>
              {% endif %}
            </div>

            <div class="ai-featured-grid__info-{{ ai_gen_id }}">
              {% if block.settings.show_vendor and product.vendor != blank %}
                <div class="ai-featured-grid__vendor-{{ ai_gen_id }}">{{ product.vendor }}</div>
              {% endif %}

              <h3 class="ai-featured-grid__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>

              {% if block.settings.show_price %}
                <div class="ai-featured-grid__price-wrapper-{{ ai_gen_id }}">
                  <span class="ai-featured-grid__price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </span>
                  
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-featured-grid__compare-price-{{ ai_gen_id }}">
                      {{ product.compare_at_price | money }}
                    </span>
                    
                    {% if block.settings.show_sale_percentage %}
                      {% assign discount = product.compare_at_price | minus: product.price %}
                      {% assign discount_percent = discount | times: 100 | divided_by: product.compare_at_price %}
                      <span class="ai-featured-grid__sale-badge-{{ ai_gen_id }}">
                        -{{ discount_percent }}%
                      </span>
                    {% endif %}
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div class="ai-featured-grid__empty-{{ ai_gen_id }}">
          <div class="ai-featured-grid__empty-icon-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
          <p class="ai-featured-grid__empty-text-{{ ai_gen_id }}">
            Add products to display in this grid
          </p>
        </div>
      {% endif %}
    </div>
  </div>
</featured-product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initGrid();
      }

      initGrid() {
        const products = this.querySelectorAll('.ai-featured-grid__product-{{ ai_gen_id }}');
        
        products.forEach((product, index) => {
          product.style.animationDelay = `${index * 0.1}s`;
        });
      }
    }

    customElements.define('featured-product-grid-{{ ai_gen_id }}', FeaturedProductGrid{{ ai_gen_id }});
  })();
</script>

