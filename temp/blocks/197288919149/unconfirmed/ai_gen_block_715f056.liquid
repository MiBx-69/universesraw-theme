{% doc %}
  @prompt
    Create a mobile-friendly newsletter signup popup section for the homepage with the following requirements:
    
    Trigger: Show only after the user has been on the page for 5 seconds AND has scrolled at least 50px — not on page load.
    
    Design:
    - Centered modal on desktop, full-width bottom sheet or centered card on mobile
    - Responsive and touch-friendly (large tap targets, font size ≥16px to prevent mobile zoom)
    - Dimmed background overlay behind the popup
    - Close (X) button in the top corner, easy to tap on mobile
    
    Content:
    - Heading: "Get 10% Off Your First Order"
    - Short subtext
    - Email input field
    - Submit button connected to Shopify's native newsletter/contact form (using customer[tags]=newsletter or contact[email] so it syncs with Shopify email marketing)
    
    Behavior:
    - Once shown, don't show again in the same session (use sessionStorage + a 1-day cookie)
    - Close on clicking outside the modal or pressing Escape key
    - Smooth fade-in and slide-up animation
    
    Technical:
    - Implement as a Liquid section (Liquid + CSS + vanilla JS, no jQuery)
    - Lazy-load the popup script so it doesn't block page load speed
    - Accessibility: focus trap inside modal, aria-labels on all interactive elements, keyboard dismiss support
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-newsletter-popup-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-newsletter-popup-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
    visibility: visible;
  }

  .ai-newsletter-popup-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-newsletter-popup-container-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) translateY(20px);
    width: 90%;
    max-width: {{ block.settings.popup_max_width }}px;
    background-color: {{ block.settings.popup_background }};
    border-radius: {{ block.settings.popup_border_radius }}px;
    padding: {{ block.settings.popup_padding }}px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    transition: transform 0.3s ease;
    max-height: 90vh;
    overflow-y: auto;
  }

  .ai-newsletter-popup-{{ ai_gen_id }}.active .ai-newsletter-popup-container-{{ ai_gen_id }} {
    transform: translate(-50%, -50%) translateY(0);
  }

  .ai-newsletter-popup-close-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.close_button_position }}px;
    right: {{ block.settings.close_button_position }}px;
    background: {{ block.settings.close_button_background }};
    border: none;
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .ai-newsletter-popup-close-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.close_button_hover_background }};
    transform: scale(1.1);
  }

  .ai-newsletter-popup-close-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.close_button_color }};
  }

  .ai-newsletter-popup-content-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-newsletter-popup-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.2;
  }

  .ai-newsletter-popup-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0 0 {{ block.settings.subtext_spacing }}px;
    line-height: 1.5;
  }

  .ai-newsletter-popup-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-newsletter-popup-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 20px;
    font-size: 16px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    transition: border-color 0.2s ease;
    min-height: 48px;
  }

  .ai-newsletter-popup-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-newsletter-popup-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
  }

  .ai-newsletter-popup-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 20px;
    font-size: 16px;
    font-weight: 600;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.1s ease;
    min-height: 48px;
  }

  .ai-newsletter-popup-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-newsletter-popup-button-{{ ai_gen_id }}:active {
    transform: scale(0.98);
  }

  .ai-newsletter-popup-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: 12px;
    font-size: 14px;
  }

  .ai-newsletter-popup-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 12px;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-newsletter-popup-container-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'bottom_sheet' %}
        top: auto;
        bottom: 0;
        left: 0;
        transform: translateY(100%);
        width: 100%;
        max-width: 100%;
        border-radius: {{ block.settings.popup_border_radius }}px {{ block.settings.popup_border_radius }}px 0 0;
        max-height: 80vh;
      {% else %}
        max-width: 95%;
      {% endif %}
    }

    .ai-newsletter-popup-{{ ai_gen_id }}.active .ai-newsletter-popup-container-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'bottom_sheet' %}
        transform: translateY(0);
      {% else %}
        transform: translate(-50%, -50%) translateY(0);
      {% endif %}
    }

    .ai-newsletter-popup-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-newsletter-popup-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<newsletter-popup-{{ ai_gen_id }}
  class="ai-newsletter-popup-{{ ai_gen_id }}"
  data-delay="{{ block.settings.trigger_delay }}"
  data-scroll="{{ block.settings.trigger_scroll }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-newsletter-popup-overlay-{{ ai_gen_id }}"></div>
  
  <div class="ai-newsletter-popup-container-{{ ai_gen_id }}" role="dialog" aria-modal="true" aria-labelledby="popup-heading-{{ ai_gen_id }}">
    <button
      class="ai-newsletter-popup-close-{{ ai_gen_id }}"
      aria-label="Close popup"
      type="button"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="ai-newsletter-popup-content-{{ ai_gen_id }}">
      {%- if block.settings.heading != blank -%}
        <h2 id="popup-heading-{{ ai_gen_id }}" class="ai-newsletter-popup-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if block.settings.subtext != blank -%}
        <div class="ai-newsletter-popup-subtext-{{ ai_gen_id }}">
          {{ block.settings.subtext }}
        </div>
      {%- endif -%}

      {%- form 'customer', class: 'ai-newsletter-popup-form-' | append: ai_gen_id -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        
        <input
          type="email"
          name="contact[email]"
          class="ai-newsletter-popup-input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.email_placeholder }}"
          aria-label="Email address"
          aria-required="true"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          required
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="popup-error-{{ ai_gen_id }}"
          {% endif %}
          {% if form.posted_successfully? %}
            aria-describedby="popup-success-{{ ai_gen_id }}"
          {% endif %}
        >

        <button
          type="submit"
          class="ai-newsletter-popup-button-{{ ai_gen_id }}"
          aria-label="Subscribe to newsletter"
        >
          {{ block.settings.button_text }}
        </button>

        {%- if form.errors -%}
          <div id="popup-error-{{ ai_gen_id }}" class="ai-newsletter-popup-error-{{ ai_gen_id }}">
            {{ form.errors.messages.email }}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div id="popup-success-{{ ai_gen_id }}" class="ai-newsletter-popup-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</newsletter-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class NewsletterPopup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.delay = parseInt(this.dataset.delay) * 1000;
        this.scrollThreshold = parseInt(this.dataset.scroll);
        this.hasScrolled = false;
        this.timeElapsed = false;
        this.isShown = false;
        this.focusableElements = null;
        this.firstFocusable = null;
        this.lastFocusable = null;
      }

      connectedCallback() {
        if (this.shouldSkipPopup()) {
          return;
        }

        this.setupEventListeners();
        this.startTimer();
        this.trackScroll();
      }

      shouldSkipPopup() {
        const sessionKey = 'newsletter_popup_shown_{{ ai_gen_id }}';
        const cookieKey = 'newsletter_popup_{{ ai_gen_id }}';
        
        if (sessionStorage.getItem(sessionKey)) {
          return true;
        }

        if (this.getCookie(cookieKey)) {
          return true;
        }

        return false;
      }

      setupEventListeners() {
        const closeButton = this.querySelector('.ai-newsletter-popup-close-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-newsletter-popup-overlay-{{ ai_gen_id }}');
        
        closeButton.addEventListener('click', () => this.closePopup());
        overlay.addEventListener('click', () => this.closePopup());
        
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.classList.contains('active')) {
            this.closePopup();
          }
          
          if (e.key === 'Tab' && this.classList.contains('active')) {
            this.handleTabKey(e);
          }
        });

        const form = this.querySelector('form');
        if (form) {
          form.addEventListener('submit', () => {
            setTimeout(() => {
              if (form.querySelector('.ai-newsletter-popup-success-{{ ai_gen_id }}')) {
                setTimeout(() => this.closePopup(), 2000);
              }
            }, 100);
          });
        }
      }

      startTimer() {
        setTimeout(() => {
          this.timeElapsed = true;
          this.checkAndShow();
        }, this.delay);
      }

      trackScroll() {
        const scrollHandler = () => {
          if (window.scrollY >= this.scrollThreshold) {
            this.hasScrolled = true;
            this.checkAndShow();
            window.removeEventListener('scroll', scrollHandler);
          }
        };

        window.addEventListener('scroll', scrollHandler);
      }

      checkAndShow() {
        if (this.timeElapsed && this.hasScrolled && !this.isShown) {
          this.showPopup();
        }
      }

      showPopup() {
        this.isShown = true;
        this.classList.add('active');
        document.body.style.overflow = 'hidden';
        
        this.setupFocusTrap();
        
        const firstInput = this.querySelector('input[type="email"]');
        if (firstInput) {
          setTimeout(() => firstInput.focus(), 100);
        }
      }

      closePopup() {
        this.classList.remove('active');
        document.body.style.overflow = '';
        
        const sessionKey = 'newsletter_popup_shown_{{ ai_gen_id }}';
        sessionStorage.setItem(sessionKey, 'true');
        
        const cookieKey = 'newsletter_popup_{{ ai_gen_id }}';
        this.setCookie(cookieKey, 'true', 1);
      }

      setupFocusTrap() {
        this.focusableElements = this.querySelectorAll(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );
        this.firstFocusable = this.focusableElements[0];
        this.lastFocusable = this.focusableElements[this.focusableElements.length - 1];
      }

      handleTabKey(e) {
        if (e.shiftKey) {
          if (document.activeElement === this.firstFocusable) {
            e.preventDefault();
            this.lastFocusable.focus();
          }
        } else {
          if (document.activeElement === this.lastFocusable) {
            e.preventDefault();
            this.firstFocusable.focus();
          }
        }
      }

      setCookie(name, value, days) {
        const date = new Date();
        date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
        const expires = 'expires=' + date.toUTCString();
        document.cookie = name + '=' + value + ';' + expires + ';path=/';
      }

      getCookie(name) {
        const nameEQ = name + '=';
        const ca = document.cookie.split(';');
        for (let i = 0; i < ca.length; i++) {
          let c = ca[i];
          while (c.charAt(0) === ' ') c = c.substring(1, c.length);
          if (c.indexOf(nameEQ) === 0) return c.substring(nameEQ.length, c.length);
        }
        return null;
      }
    }

    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => {
        customElements.define('newsletter-popup-{{ ai_gen_id }}', NewsletterPopup{{ ai_gen_id }});
      });
    } else {
      setTimeout(() => {
        customElements.define('newsletter-popup-{{ ai_gen_id }}', NewsletterPopup{{ ai_gen_id }});
      }, 100);
    }
  })();
</script>

