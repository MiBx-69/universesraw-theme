{% doc %}
  @prompt
    Create a premium, mobile-first newsletter signup popup for the Universes RAW Shopify store. The design should match a modern luxury fashion brand with a minimalist aesthetic, black and white color palette, subtle animations, rounded corners, soft shadows, and excellent performance.
    
    Popup Trigger Rules
    Display only on the Home page.
    Show only after both conditions are met:
    The visitor has been on the page for at least 5 seconds.
    The visitor has scrolled at least 25% of the page.
    Show only once every 7 days using browser storage (localStorage or cookies).
    Do not show if the customer has already subscribed to the newsletter.
    Do not show again during the same browsing session after the popup is closed.
    Work perfectly on desktop, tablet, and mobile devices.
    Popup Design
    
    Create a premium luxury popup that feels elegant and high-end.
    
    White background
    Black typography
    Rounded corners (16–20px)
    Soft shadow
    Smooth fade and slide-up animation
    Full-screen semi-transparent dark overlay
    Large touch-friendly close button
    Maximum width: 420px
    Mobile optimized with proper spacing and typography
    Popup Content
    
    Headline
    Join the Universes RAW Club
    
    Subheading
    Get exclusive offers, early access to new arrivals, and members-only promotions.
    
    Email Field
    Placeholder:
    Enter your email address
    
    Primary Button
    Join Now
    
    Trust Text
    ✓ Exclusive member discounts
    ✓ Early access to new collections
    ✓ No spam. Unsubscribe anytime.
    
    Functionality
    Use Shopify's native customer newsletter form.
    Submit directly to Shopify Customers for Email Marketing.
    Validate email addresses.
    Show a success message after submission without reloading the page.
    Handle errors gracefully.
    Ensure accessibility with proper labels, keyboard navigation, and ARIA attributes.
    Lazy load assets where possible.
    Avoid layout shift and maintain high Lighthouse performance scores.
    Animation
    Fade in + slight slide up when opening.
    Fade out when closing.
    Duration: 300ms.
    Respect users who prefer reduced motion.
    Performance
    Lightweight implementation.
    No unnecessary JavaScript libraries.
    Optimized for Shopify Online Store 2.0.
    Compatible with Dawn and other OS 2.0 themes.
    Avoid blocking page rendering.
    Theme Editor Support
    
    Create this as a reusable Shopify section with customizable settings, including:
    
    Enable/Disable popup
    Delay time (default 5 seconds)
    Scroll percentage trigger (default 25%)
    Popup title
    Description
    Button text
    Success message
    Background color
    Text color
    Button colors
    Border radius
    Overlay opacity
    Show on desktop
    Show on mobile
    Show once every X days
    Enable discount code after signup
    
    Generate clean, well-commented Liquid, HTML, CSS, and JavaScript following Shopify Online Store 2.0 best practices, ensuring responsive design, accessibility, SEO, maintainability, and a premium luxury user experience consistent with the Universes RAW brand.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-newsletter-popup-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-newsletter-popup-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-newsletter-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-newsletter-popup-{{ ai_gen_id }}.active .ai-newsletter-overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-newsletter-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.popup_max_width }}px;
    background-color: {{ block.settings.popup_background }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    padding: {{ block.settings.padding_desktop }}px;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-newsletter-container-{{ ai_gen_id }} {
      transition: opacity 0.3s ease;
      transform: none;
    }
  }

  .ai-newsletter-popup-{{ ai_gen_id }}.active .ai-newsletter-container-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-newsletter-close-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.close_button_position }}px;
    right: {{ block.settings.close_button_position }}px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.text_color }};
    transition: opacity 0.2s ease;
    z-index: 10;
  }

  .ai-newsletter-close-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-newsletter-close-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-newsletter-content-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-newsletter-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-newsletter-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.form_spacing }}px;
    line-height: 1.5;
    opacity: 0.8;
  }

  .ai-newsletter-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.input_spacing }}px;
  }

  .ai-newsletter-input-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_font_size }}px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.input_background }};
    transition: border-color 0.2s ease;
  }

  .ai-newsletter-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.button_background }};
  }

  .ai-newsletter-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  .ai-newsletter-button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .ai-newsletter-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-newsletter-button-{{ ai_gen_id }}:active {
    transform: translateY(0);
  }

  .ai-newsletter-trust-{{ ai_gen_id }} {
    margin-top: {{ block.settings.trust_spacing }}px;
    font-size: {{ block.settings.trust_font_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    line-height: 1.6;
  }

  .ai-newsletter-trust-{{ ai_gen_id }} p {
    margin: 4px 0;
  }

  .ai-newsletter-success-{{ ai_gen_id }},
  .ai-newsletter-error-{{ ai_gen_id }} {
    margin-top: 16px;
    padding: 12px;
    border-radius: 8px;
    font-size: 14px;
    text-align: center;
  }

  .ai-newsletter-success-{{ ai_gen_id }} {
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .ai-newsletter-error-{{ ai_gen_id }} {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  @media screen and (max-width: 749px) {
    .ai-newsletter-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_mobile }}px;
      max-width: 100%;
    }

    .ai-newsletter-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-newsletter-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-newsletter-close-{{ ai_gen_id }} {
      top: {{ block.settings.close_button_position | times: 0.7 }}px;
      right: {{ block.settings.close_button_position | times: 0.7 }}px;
    }
  }

  {% if block.settings.show_on_desktop == false %}
    @media screen and (min-width: 750px) {
      .ai-newsletter-popup-{{ ai_gen_id }} {
        display: none !important;
      }
    }
  {% endif %}

  {% if block.settings.show_on_mobile == false %}
    @media screen and (max-width: 749px) {
      .ai-newsletter-popup-{{ ai_gen_id }} {
        display: none !important;
      }
    }
  {% endif %}
{% endstyle %}

<newsletter-popup-{{ ai_gen_id }}
  class="ai-newsletter-popup-{{ ai_gen_id }}"
  data-enabled="{{ block.settings.enable_popup }}"
  data-delay="{{ block.settings.delay_seconds }}"
  data-scroll="{{ block.settings.scroll_percentage }}"
  data-days="{{ block.settings.show_once_days }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-newsletter-overlay-{{ ai_gen_id }}"></div>
  
  <div class="ai-newsletter-container-{{ ai_gen_id }}">
    <button
      type="button"
      class="ai-newsletter-close-{{ ai_gen_id }}"
      aria-label="Close popup"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="ai-newsletter-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-newsletter-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-newsletter-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}

      {% form 'customer', class: 'ai-newsletter-form-' | append: ai_gen_id %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        
        <input
          type="email"
          name="contact[email]"
          class="ai-newsletter-input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.email_placeholder }}"
          aria-label="Email address"
          autocomplete="email"
          required
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="ai-newsletter-error-{{ ai_gen_id }}"
          {% endif %}
          {% if form.posted_successfully? %}
            aria-describedby="ai-newsletter-success-{{ ai_gen_id }}"
          {% endif %}
        >

        <button
          type="submit"
          class="ai-newsletter-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </button>

        {% if form.posted_successfully? %}
          <div
            id="ai-newsletter-success-{{ ai_gen_id }}"
            class="ai-newsletter-success-{{ ai_gen_id }}"
          >
            {{ block.settings.success_message }}
          </div>
        {% endif %}

        {% if form.errors %}
          <div
            id="ai-newsletter-error-{{ ai_gen_id }}"
            class="ai-newsletter-error-{{ ai_gen_id }}"
          >
            {% if form.errors.messages.email %}
              {{ form.errors.messages.email }}
            {% else %}
              Please enter a valid email address.
            {% endif %}
          </div>
        {% endif %}
      {% endform %}

      {% if block.settings.trust_text != blank %}
        <div class="ai-newsletter-trust-{{ ai_gen_id }}">
          {{ block.settings.trust_text }}
        </div>
      {% endif %}
    </div>
  </div>
</newsletter-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class NewsletterPopup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.enabled = this.dataset.enabled === 'true';
        this.delay = parseInt(this.dataset.delay) * 1000;
        this.scrollPercentage = parseInt(this.dataset.scroll);
        this.cookieDays = parseInt(this.dataset.days);
        this.storageKey = 'ai_newsletter_popup_{{ ai_gen_id }}_closed';
        this.sessionKey = 'ai_newsletter_popup_{{ ai_gen_id }}_session';
        this.subscribedKey = 'ai_newsletter_popup_{{ ai_gen_id }}_subscribed';
        
        this.timeConditionMet = false;
        this.scrollConditionMet = false;
        this.hasShown = false;
      }

      connectedCallback() {
        if (!this.enabled) return;
        
        if (this.shouldShow()) {
          this.setupEventListeners();
          this.startTracking();
        }
      }

      shouldShow() {
        if (typeof window === 'undefined') return false;
        
        if (window.location.pathname !== '/') return false;
        
        if (sessionStorage.getItem(this.sessionKey)) return false;
        
        if (localStorage.getItem(this.subscribedKey)) return false;
        
        const closedTime = localStorage.getItem(this.storageKey);
        if (closedTime) {
          const daysSinceClosed = (Date.now() - parseInt(closedTime)) / (1000 * 60 * 60 * 24);
          if (daysSinceClosed < this.cookieDays) return false;
        }
        
        return true;
      }

      setupEventListeners() {
        const closeButton = this.querySelector('.ai-newsletter-close-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-newsletter-overlay-{{ ai_gen_id }}');
        const form = this.querySelector('.ai-newsletter-form-{{ ai_gen_id }}');

        if (closeButton) {
          closeButton.addEventListener('click', () => this.closePopup());
        }

        if (overlay) {
          overlay.addEventListener('click', () => this.closePopup());
        }

        if (form) {
          form.addEventListener('submit', () => {
            setTimeout(() => {
              if (this.querySelector('.ai-newsletter-success-{{ ai_gen_id }}')) {
                localStorage.setItem(this.subscribedKey, Date.now().toString());
                setTimeout(() => this.closePopup(), 3000);
              }
            }, 100);
          });
        }

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.classList.contains('active')) {
            this.closePopup();
          }
        });
      }

      startTracking() {
        setTimeout(() => {
          this.timeConditionMet = true;
          this.checkConditions();
        }, this.delay);

        const scrollHandler = () => {
          const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
          const docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          const scrollPercent = (scrollTop / docHeight) * 100;

          if (scrollPercent >= this.scrollPercentage) {
            this.scrollConditionMet = true;
            this.checkConditions();
          }
        };

        window.addEventListener('scroll', scrollHandler, { passive: true });
      }

      checkConditions() {
        if (this.timeConditionMet && this.scrollConditionMet && !this.hasShown) {
          this.showPopup();
          this.hasShown = true;
        }
      }

      showPopup() {
        this.classList.add('active');
        document.body.style.overflow = 'hidden';
        
        const firstInput = this.querySelector('.ai-newsletter-input-{{ ai_gen_id }}');
        if (firstInput) {
          setTimeout(() => firstInput.focus(), 300);
        }
      }

      closePopup() {
        this.classList.remove('active');
        document.body.style.overflow = '';
        localStorage.setItem(this.storageKey, Date.now().toString());
        sessionStorage.setItem(this.sessionKey, 'true');
      }
    }

    customElements.define('newsletter-popup-{{ ai_gen_id }}', NewsletterPopup{{ ai_gen_id }});
  })();
</script>

