{% doc %}
  @prompt
    Redesign the Shopify Featured Products section to match the premium editorial fashion aesthetic shown in the reference image.
    
    DO NOT create a generic Shopify product grid.
    
    The section should feel like a luxury fashion brand similar to COS, ARKET, Fear of God, or the reference design.
    
    ====================
    SECTION HEADER
    ====================
    
    Create a clean editorial header.
    
    Top left:
    Small uppercase label:
    "THE EDIT"
    
    Style:
    - Font Size: 11px
    - Letter Spacing: 0.25em
    - Font Weight: 600
    - Color: #C23A45
    
    Below it:
    
    Large serif heading:
    
    Featured selection
    
    Use an elegant editorial serif font similar to:
    Canela
    Cormorant Garamond
    PP Editorial New
    
    Desktop:
    46px
    
    Mobile:
    34px
    
    Weight:
    400
    
    Color:
    #111111
    
    Below heading:
    
    Handpicked pieces from our latest drop.
    
    Font:
    Inter
    
    16px
    
    Color:
    #666
    
    On the right side:
    
    SHOP ALL
    
    Uppercase
    
    Letter spacing:
    0.35em
    
    Small underline
    
    Hover animation:
    Underline expands smoothly.
    
    ====================
    LAYOUT
    ====================
    
    Desktop:
    4 products per row
    
    Tablet:
    3 products
    
    Mobile:
    2 products
    
    Large white spacing
    
    Modern editorial alignment
    
    Maximum width:
    1400px
    
    Section padding:
    
    Desktop:
    100px top
    80px bottom
    
    Mobile:
    48px
    
    ====================
    PRODUCT CARD
    ====================
    
    Premium minimal product card.
    
    No visible border.
    
    White background.
    
    Image container:
    
    Rounded corners:
    18px
    
    Background:
    #F6F6F6
    
    Overflow hidden.
    
    Hover:
    
    Image zoom:
    scale(1.04)
    
    Transition:
    400ms cubic-bezier(.22,.61,.36,1)
    
    Shadow:
    
    0 20px 60px rgba(0,0,0,.08)
    
    Entire card lifts:
    translateY(-4px)
    
    ====================
    SALE BADGE
    ====================
    
    Top left
    
    Dynamic Shopify discount percentage.
    
    Example:
    
    -26%
    
    Background:
    #BE2332
    
    White text
    
    Border radius:
    999px
    
    Height:
    24px
    
    Padding:
    6px 10px
    
    Font:
    11px
    
    Weight:
    600
    
    ====================
    PRODUCT IMAGE
    ====================
    
    Large image.
    
    Centered.
    
    Object-fit:
    contain
    
    Maintain original product ratio.
    
    Hover:
    
    Fade into second product image if available.
    
    Smooth transition.
    
    ====================
    PRODUCT INFORMATION
    ====================
    
    Brand
    
    Uppercase
    
    Letter spacing:
    0.22em
    
    11px
    
    Color:
    #777
    
    Product Title
    
    15px
    
    Medium weight
    
    Maximum:
    2 lines
    
    Clamp after two lines.
    
    Price
    
    Current price:
    
    18px
    
    Weight:
    700
    
    Old price:
    
    14px
    
    Gray
    
    Line-through
    
    Dynamic Shopify pricing.
    
    ====================
    COLOR SWATCHES
    ====================
    
    Display available color variants.
    
    Small circles
    
    10px
    
    Gap:
    8px
    
    Active color:
    
    Black border
    
    Hover:
    
    Scale slightly.
    
    ====================
    SIZE OPTIONS
    ====================
    
    Display available sizes.
    
    Example:
    
    40 · 41 · 42 · 43 · 44
    
    Font:
    11px
    
    Color:
    #777
    
    Spacing:
    6px
    
    ====================
    QUICK ADD
    ====================
    
    Desktop:
    
    Quick Add button slides up over image on hover.
    
    Button:
    
    Black background
    
    White text
    
    Rounded
    
    Height:
    42px
    
    Smooth animation.
    
    Mobile:
    
    Always visible.
    
    ====================
    SHOPIFY FEATURES
    ====================
    
    Use Shopify Featured Collection.
    
    Dynamic Products
    
    Dynamic Prices
    
    Dynamic Compare-at Price
    
    Dynamic Discount Percentage
    
    Dynamic Variants
    
    Dynamic Images
    
    Dynamic Quick Add
    
    Shopify Theme Editor compatible.
    
    No hardcoded products.
    
    ====================
    ANIMATIONS
    ====================
    
    Fade in when section enters viewport.
    
    Hover:
    
    Image zoom
    
    Card lift
    
    Button slide
    
    Second image fade
    
    Wishlist icon fade
    
    Everything should animate smoothly using CSS transitions.
    
    ====================
    DESIGN STYLE
    ====================
    
    The final result should look identical in quality to the provided reference.
    
    Luxury.
    
    Editorial.
    
    Minimal.
    
    Premium.
    
    Fashion-forward.
    
    Apple-level spacing.
    
    No unnecessary borders.
    
    No heavy shadows.
    
    Excellent typography.
    
    Perfect mobile responsiveness.
    
    Fast loading.
    
    Clean semantic HTML.
    
    Use Liquid, CSS, and vanilla JavaScript only.
    
    The section should be fully customizable from the Shopify Theme Editor, allowing changes to the heading, subheading, button text, collection source, number of products, colors, spacing, and typography without modifying the code.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-editorial-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.section_background }};
  }

  .ai-featured-editorial-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-featured-editorial-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: {{ block.settings.header_spacing }}px;
    gap: 20px;
  }

  .ai-featured-editorial-header-left-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-featured-editorial-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    letter-spacing: 0.25em;
    font-weight: {{ block.settings.label_weight }};
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    margin: 0 0 {{ block.settings.label_margin }}px;
  }

  .ai-featured-editorial-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin }}px;
    line-height: 1.2;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-style: {{ block.settings.heading_font.style }};
  }

  .ai-featured-editorial-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-featured-editorial-shop-all-{{ ai_gen_id }} {
    text-decoration: none;
    color: {{ block.settings.shop_all_color }};
    font-size: {{ block.settings.shop_all_size }}px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-weight: {{ block.settings.shop_all_weight }};
    position: relative;
    display: inline-block;
    padding-bottom: 4px;
    white-space: nowrap;
  }

  .ai-featured-editorial-shop-all-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.shop_all_color }};
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .ai-featured-editorial-shop-all-{{ ai_gen_id }}:hover::after {
    transform: scaleX(1.2);
  }

  .ai-featured-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-featured-editorial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: visible;
    transition: transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1), box-shadow 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
    position: relative;
  }

  .ai-featured-editorial-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
  }

  .ai-featured-editorial-image-container-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.image_background }};
    border-radius: {{ block.settings.image_radius }}px;
    overflow: hidden;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-featured-editorial-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .ai-featured-editorial-card-{{ ai_gen_id }}:hover .ai-featured-editorial-image-{{ ai_gen_id }} {
    transform: scale(1.04);
  }

  .ai-featured-editorial-image-secondary-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .ai-featured-editorial-card-{{ ai_gen_id }}:hover .ai-featured-editorial-image-secondary-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-featured-editorial-badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_top }}px;
    left: {{ block.settings.badge_left }}px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_color }};
    border-radius: {{ block.settings.badge_radius }}px;
    height: {{ block.settings.badge_height }}px;
    padding: 0 {{ block.settings.badge_padding }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.badge_size }}px;
    font-weight: {{ block.settings.badge_weight }};
    z-index: 2;
  }

  .ai-featured-editorial-info-{{ ai_gen_id }} {
    padding: {{ block.settings.info_padding }}px 0 0;
  }

  .ai-featured-editorial-brand-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_size }}px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ block.settings.brand_color }};
    margin: 0 0 {{ block.settings.brand_margin }}px;
  }

  .ai-featured-editorial-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin }}px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-featured-editorial-title-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
  }

  .ai-featured-editorial-price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: {{ block.settings.price_margin }}px;
  }

  .ai-featured-editorial-price-current-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    color: {{ block.settings.price_color }};
  }

  .ai-featured-editorial-price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-featured-editorial-swatches-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.swatch_gap }}px;
    margin-bottom: {{ block.settings.swatch_margin }}px;
  }

  .ai-featured-editorial-swatch-{{ ai_gen_id }} {
    width: {{ block.settings.swatch_size }}px;
    height: {{ block.settings.swatch_size }}px;
    border-radius: 50%;
    border: 1px solid transparent;
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .ai-featured-editorial-swatch-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
  }

  .ai-featured-editorial-swatch-active-{{ ai_gen_id }} {
    border-color: {{ block.settings.swatch_active_border }};
    border-width: 2px;
  }

  .ai-featured-editorial-sizes-{{ ai_gen_id }} {
    font-size: {{ block.settings.size_font_size }}px;
    color: {{ block.settings.size_color }};
    margin-bottom: {{ block.settings.size_margin }}px;
  }

  .ai-featured-editorial-quick-add-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: {{ block.settings.quick_add_background }};
    color: {{ block.settings.quick_add_color }};
    border: none;
    height: {{ block.settings.quick_add_height }}px;
    border-radius: {{ block.settings.quick_add_radius }}px;
    font-size: {{ block.settings.quick_add_size }}px;
    font-weight: {{ block.settings.quick_add_weight }};
    cursor: pointer;
    transform: translateY(100%);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.3s cubic-bezier(0.22, 0.61, 0.36, 1);
    z-index: 3;
  }

  .ai-featured-editorial-card-{{ ai_gen_id }}:hover .ai-featured-editorial-quick-add-{{ ai_gen_id }} {
    transform: translateY(0);
    opacity: 1;
  }

  @media screen and (max-width: 989px) {
    .ai-featured-editorial-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px 16px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-featured-editorial-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .ai-featured-editorial-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-featured-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-featured-editorial-quick-add-{{ ai_gen_id }} {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-featured-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }
{% endstyle %}

<editorial-featured-products-{{ ai_gen_id }} class="ai-featured-editorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-editorial-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-featured-editorial-header-{{ ai_gen_id }}">
        <div class="ai-featured-editorial-header-left-{{ ai_gen_id }}">
          {% if block.settings.label != blank %}
            <div class="ai-featured-editorial-label-{{ ai_gen_id }}">{{ block.settings.label }}</div>
          {% endif %}
          {% if block.settings.heading != blank %}
            <h2 class="ai-featured-editorial-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.subtext != blank %}
            <p class="ai-featured-editorial-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
          {% endif %}
        </div>
        {% if block.settings.show_shop_all and block.settings.collection != blank %}
          <a href="{{ block.settings.collection.url }}" class="ai-featured-editorial-shop-all-{{ ai_gen_id }}">
            {{ block.settings.shop_all_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-featured-editorial-grid-{{ ai_gen_id }}">
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-featured-editorial-card-{{ ai_gen_id }}">
            <div class="ai-featured-editorial-image-container-{{ ai_gen_id }}">
              {% if product.compare_at_price > product.price %}
                {% assign discount_percent = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                <div class="ai-featured-editorial-badge-{{ ai_gen_id }}">-{{ discount_percent }}%</div>
              {% endif %}

              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-featured-editorial-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | divided_by: product.featured_image.aspect_ratio | round }}"
                >
              {% else %}
                <div class="ai-featured-editorial-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if product.media[1] %}
                <img
                  src="{{ product.media[1] | image_url: width: 800 }}"
                  alt="{{ product.media[1].alt | escape }}"
                  class="ai-featured-editorial-image-secondary-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | divided_by: product.media[1].aspect_ratio | round }}"
                >
              {% endif %}

              {% if block.settings.show_quick_add %}
                <button class="ai-featured-editorial-quick-add-{{ ai_gen_id }}" data-product-id="{{ product.id }}">
                  {{ block.settings.quick_add_text }}
                </button>
              {% endif %}
            </div>

            <div class="ai-featured-editorial-info-{{ ai_gen_id }}">
              {% if block.settings.show_vendor and product.vendor != blank %}
                <div class="ai-featured-editorial-brand-{{ ai_gen_id }}">{{ product.vendor }}</div>
              {% endif %}

              <h3 class="ai-featured-editorial-title-{{ ai_gen_id }}">
                <a href="{{ product.url }}" class="ai-featured-editorial-title-link-{{ ai_gen_id }}">
                  {{ product.title }}
                </a>
              </h3>

              <div class="ai-featured-editorial-price-{{ ai_gen_id }}">
                <span class="ai-featured-editorial-price-current-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </span>
                {% if product.compare_at_price > product.price %}
                  <span class="ai-featured-editorial-price-compare-{{ ai_gen_id }}">
                    {{ product.compare_at_price | money }}
                  </span>
                {% endif %}
              </div>

              {% if block.settings.show_color_swatches %}
                {% assign color_option = product.options_with_values | where: 'name', 'Color' | first %}
                {% if color_option %}
                  <div class="ai-featured-editorial-swatches-{{ ai_gen_id }}">
                    {% for value in color_option.values limit: 5 %}
                      {% assign color_value = value | downcase | replace: ' ', '-' %}
                      <div
                        class="ai-featured-editorial-swatch-{{ ai_gen_id }}"
                        style="background-color: {{ value | downcase | replace: ' ', '' }};"
                        title="{{ value }}"
                      ></div>
                    {% endfor %}
                  </div>
                {% endif %}
              {% endif %}

              {% if block.settings.show_sizes %}
                {% assign size_option = product.options_with_values | where: 'name', 'Size' | first %}
                {% if size_option %}
                  <div class="ai-featured-editorial-sizes-{{ ai_gen_id }}">
                    {% for value in size_option.values %}
                      {{ value }}{% unless forloop.last %} · {% endunless %}
                    {% endfor %}
                  </div>
                {% endif %}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-featured-editorial-empty-{{ ai_gen_id }}" style="text-align: center; padding: 60px 20px; color: #999;">
        Select a collection to display products
      </div>
    {% endif %}
  </div>
</editorial-featured-products-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialFeaturedProducts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.quickAddButtons = this.querySelectorAll('.ai-featured-editorial-quick-add-{{ ai_gen_id }}');
        this.setupQuickAdd();
      }

      setupQuickAdd() {
        this.quickAddButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const productId = button.getAttribute('data-product-id');
            this.addToCart(productId);
          });
        });
      }

      addToCart(productId) {
        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: productId,
            quantity: 1
          })
        })
        .then(response => response.json())
        .then(data => {
          window.location.href = '/cart';
        })
        .catch((error) => {
          console.error('Error:', error);
        });
      }
    }

    customElements.define('editorial-featured-products-{{ ai_gen_id }}', EditorialFeaturedProducts{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Editorial products",
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 8
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "THE EDIT"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured selection"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Handpicked pieces from our latest drop."
    },
    {
      "type": "checkbox",
      "id": "show_shop_all",
      "label": "Show shop all link",
      "default": true
    },
    {
      "type": "text",
      "id": "shop_all_text",
      "label": "Shop all text",
      "default": "SHOP ALL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "products_per_row_tablet",
