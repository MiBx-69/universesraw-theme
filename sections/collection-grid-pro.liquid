{% comment %}Professional Collection Grid{% endcomment %}

{%- liquid
  assign section_anchor = 'CollectionGridPro-' | append: section.id
-%}

<section
  id="{{ section_anchor }}"
  class="collection-grid-pro color-{{ section.settings.color_scheme }}"
  style="
    --pcg-max-width: {% if section.settings.section_width == 'full' %}100%{% else %}{{ section.settings.max_width }}px{% endif %};
    --pcg-padding-top: {{ section.settings.padding_top }}px;
    --pcg-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pcg-padding-x: {{ section.settings.side_padding }}px;
    --pcg-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --pcg-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --pcg-mobile-padding-x: {{ section.settings.mobile_side_padding }}px;
    --pcg-grid-gap: {{ section.settings.grid_gap }}px;
    --pcg-mobile-grid-gap: {{ section.settings.mobile_grid_gap }}px;
    --pcg-title-gap: {{ section.settings.title_gap }}px;
    --pcg-image-radius: {{ section.settings.image_radius }}px;
    --pcg-image-bg: {{ section.settings.image_background }};
    --pcg-title-color: {{ section.settings.title_color }};
    --pcg-title-size: {{ section.settings.title_size }}px;
    --pcg-mobile-title-size: {{ section.settings.mobile_title_size }}px;
    --pcg-title-weight: {{ section.settings.title_weight }};
    --pcg-title-transform: {{ section.settings.title_transform }};
    --pcg-title-align: {{ section.settings.title_align }};
    --pcg-letter-spacing: {{ section.settings.title_letter_spacing | divided_by: 100.0 }}em;
    --pcg-hover-scale: {{ section.settings.hover_scale | divided_by: 100.0 | plus: 1 }};
    --pcg-card-opacity: {{ section.settings.image_opacity | divided_by: 100.0 }};
    --pcg-shadow-opacity: {{ section.settings.shadow_opacity | divided_by: 100.0 }};
  "
>
  <div class="collection-grid-pro__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="collection-grid-pro__header collection-grid-pro__header--{{ section.settings.header_align }}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="collection-grid-pro__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="collection-grid-pro__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <div class="collection-grid-pro__subheading">{{ section.settings.subheading }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="collection-grid-pro__grid collection-grid-pro__grid--desktop-{{ section.settings.desktop_columns }} collection-grid-pro__grid--mobile-{{ section.settings.mobile_columns }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_collection = block.settings.collection
          assign card_image = block.settings.image | default: card_collection.featured_image
          assign card_title = block.settings.title | default: card_collection.title
          assign card_url = card_collection.url
          assign image_alt = block.settings.image.alt | default: card_collection.featured_image.alt | default: card_title
        -%}

        {%- if card_collection != blank -%}
          <a
            class="collection-grid-pro__card"
            href="{{ card_url }}"
            aria-label="{{ card_title | escape }}"
            {{ block.shopify_attributes }}
          >
        {%- else -%}
          <div class="collection-grid-pro__card collection-grid-pro__card--empty" {{ block.shopify_attributes }}>
        {%- endif -%}
          <div class="collection-grid-pro__media collection-grid-pro__media--{{ section.settings.image_ratio }}">
            {%- if card_image != blank -%}
              {{
                card_image
                | image_url: width: 1800
                | image_tag:
                  loading: 'lazy',
                  widths: '320, 480, 640, 750, 900, 1100, 1400, 1800',
                  sizes: '(min-width: 1200px) calc((var(--pcg-max-width) - (var(--pcg-grid-gap) * 3)) / 4), (min-width: 750px) 33vw, 50vw',
                  alt: image_alt,
                  class: 'collection-grid-pro__image'
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'collection-grid-pro__placeholder' }}
            {%- endif -%}
          </div>

          <{{ section.settings.title_tag }} class="collection-grid-pro__title">
            {%- if card_title != blank -%}
              {{ card_title | escape }}
            {%- else -%}
              Collection
            {%- endif -%}
          </{{ section.settings.title_tag }}>
        {%- if card_collection != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #{{ section_anchor }} {
    background: {{ section.settings.background_color }};
    padding: var(--pcg-padding-top) var(--pcg-padding-x) var(--pcg-padding-bottom);
  }

  #{{ section_anchor }} .collection-grid-pro__inner {
    width: 100%;
    max-width: var(--pcg-max-width);
    margin: 0 auto;
  }

  #{{ section_anchor }} .collection-grid-pro__header {
    max-width: 760px;
    margin: 0 auto {{ section.settings.header_gap }}px;
  }

  #{{ section_anchor }} .collection-grid-pro__header--left {
    margin-left: 0;
    text-align: left;
  }

  #{{ section_anchor }} .collection-grid-pro__header--center {
    text-align: center;
  }

  #{{ section_anchor }} .collection-grid-pro__header--right {
    margin-right: 0;
    text-align: right;
  }

  #{{ section_anchor }} .collection-grid-pro__eyebrow {
    margin: 0 0 10px;
    color: {{ section.settings.eyebrow_color }};
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 600;
    letter-spacing: .16em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .collection-grid-pro__heading {
    margin: 0;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: 0;
    line-height: 1.08;
  }

  #{{ section_anchor }} .collection-grid-pro__subheading {
    margin-top: 14px;
    color: {{ section.settings.subheading_color }};
    font-size: {{ section.settings.subheading_size }}px;
    line-height: 1.55;
  }

  #{{ section_anchor }} .collection-grid-pro__subheading p {
    margin: 0;
  }

  #{{ section_anchor }} .collection-grid-pro__grid {
    display: grid;
    gap: var(--pcg-grid-gap);
  }

  #{{ section_anchor }} .collection-grid-pro__grid--desktop-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  #{{ section_anchor }} .collection-grid-pro__grid--desktop-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  #{{ section_anchor }} .collection-grid-pro__grid--desktop-4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  #{{ section_anchor }} .collection-grid-pro__grid--desktop-5 {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  #{{ section_anchor }} .collection-grid-pro__card {
    display: block;
    min-width: 0;
    color: inherit;
    text-decoration: none;
  }

  #{{ section_anchor }} .collection-grid-pro__media {
    position: relative;
    overflow: hidden;
    background: var(--pcg-image-bg);
    border-radius: var(--pcg-image-radius);
    box-shadow: 0 18px 46px rgba(0, 0, 0, var(--pcg-shadow-opacity));
    isolation: isolate;
  }

  #{{ section_anchor }} .collection-grid-pro__media--adapt {
    aspect-ratio: auto;
  }

  #{{ section_anchor }} .collection-grid-pro__media--square {
    aspect-ratio: 1 / 1;
  }

  #{{ section_anchor }} .collection-grid-pro__media--portrait {
    aspect-ratio: 4 / 5;
  }

  #{{ section_anchor }} .collection-grid-pro__media--tall {
    aspect-ratio: 3 / 4;
  }

  #{{ section_anchor }} .collection-grid-pro__media--landscape {
    aspect-ratio: 16 / 10;
  }

  #{{ section_anchor }} .collection-grid-pro__image,
  #{{ section_anchor }} .collection-grid-pro__placeholder {
    display: block;
    width: 100%;
  }

  #{{ section_anchor }} .collection-grid-pro__image {
    height: auto;
    opacity: var(--pcg-card-opacity);
    object-position: {{ section.settings.image_position }};
    transition: transform 700ms cubic-bezier(.22, 1, .36, 1), opacity 700ms cubic-bezier(.22, 1, .36, 1);
  }

  #{{ section_anchor }} .collection-grid-pro__media:not(.collection-grid-pro__media--adapt) .collection-grid-pro__image,
  #{{ section_anchor }} .collection-grid-pro__media:not(.collection-grid-pro__media--adapt) .collection-grid-pro__placeholder {
    height: 100%;
    object-fit: cover;
  }

  #{{ section_anchor }} .collection-grid-pro__placeholder {
    min-height: 220px;
    background: var(--pcg-image-bg);
  }

  #{{ section_anchor }} .collection-grid-pro__title {
    margin: var(--pcg-title-gap) 0 0;
    color: var(--pcg-title-color);
    font-size: var(--pcg-title-size);
    font-weight: var(--pcg-title-weight);
    letter-spacing: var(--pcg-letter-spacing);
    line-height: 1.22;
    text-align: var(--pcg-title-align);
    text-transform: var(--pcg-title-transform);
  }

  @media (hover: hover) {
    #{{ section_anchor }} .collection-grid-pro__card:hover .collection-grid-pro__image {
      transform: scale(var(--pcg-hover-scale));
    }
  }

  @media screen and (max-width: 989px) {
    #{{ section_anchor }} .collection-grid-pro__grid--desktop-4,
    #{{ section_anchor }} .collection-grid-pro__grid--desktop-5 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    #{{ section_anchor }} {
      padding: var(--pcg-mobile-padding-top) var(--pcg-mobile-padding-x) var(--pcg-mobile-padding-bottom);
    }

    #{{ section_anchor }} .collection-grid-pro__header {
      margin-bottom: {{ section.settings.mobile_header_gap }}px;
      text-align: {{ section.settings.mobile_header_align }};
    }

    #{{ section_anchor }} .collection-grid-pro__heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
    }

    #{{ section_anchor }} .collection-grid-pro__subheading {
      font-size: {{ section.settings.mobile_subheading_size }}px;
    }

    #{{ section_anchor }} .collection-grid-pro__grid {
      gap: var(--pcg-mobile-grid-gap);
    }

    #{{ section_anchor }} .collection-grid-pro__grid--mobile-1 {
      grid-template-columns: 1fr;
    }

    #{{ section_anchor }} .collection-grid-pro__grid--mobile-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #{{ section_anchor }} .collection-grid-pro__title {
      font-size: var(--pcg-mobile-title-size);
    }
  }
</style>

{% schema %}
{
  "name": "Collection Grid Pro",
  "tag": "section",
  "class": "section-collection-grid-pro",
  "disabled_on": {
    "groups": ["header", "footer", "custom.popup", "aside"]
