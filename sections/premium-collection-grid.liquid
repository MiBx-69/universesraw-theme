{% comment %}
Premium Collection Grid
Simplified starter version for Shopify OS 2.0
Save as: sections/premium-collection-grid.liquid
{% endcomment %}

<section class="premium-grid page-width">
  {% if section.settings.heading != blank %}
    <div class="section-header">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="grid desktop-{{ section.settings.desktop_columns }} mobile-{{ section.settings.mobile_columns }}">
    {% for block in section.blocks %}
      {% assign col = block.settings.collection %}
      <a class="card" href="{{ col.url }}" {{ block.shopify_attributes }}>
        <div class="media">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {% elsif col.featured_image %}
            {{ col.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: col.title }}
          {% endif %}
          <div class="overlay"></div>
        </div>

        <div class="content">
          <h3>
            {% if block.settings.title != blank %}
              {{ block.settings.title }}
            {% else %}
              {{ col.title }}
            {% endif %}
          </h3>

          {% if block.settings.subtitle != blank %}
            <p>{{ block.settings.subtitle }}</p>
          {% endif %}

          <span class="btn">{{ section.settings.button_text }}</span>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

<style>
.premium-grid{padding:60px 0}
.section-header{text-align:center;margin-bottom:40px}
.section-header h2{font-size:36px;letter-spacing:.08em}
.section-header p{opacity:.7}
.grid{display:grid;gap:24px}
.desktop-2{grid-template-columns:repeat(2,1fr)}
.desktop-3{grid-template-columns:repeat(3,1fr)}
.desktop-4{grid-template-columns:repeat(4,1fr)}
.card{position:relative;border-radius:18px;overflow:hidden;color:#fff;text-decoration:none}
.media{aspect-ratio:4/5;position:relative}
.media img{width:100%;height:100%;object-fit:cover;transition:.5s}
.overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.6),rgba(0,0,0,.15))}
.content{position:absolute;left:24px;bottom:24px;z-index:2}
.content h3{margin:0 0 6px;font-size:26px}
.content p{margin:0 0 16px;opacity:.9}
.btn{display:inline-block;border:1px solid #fff;padding:10px 18px;border-radius:30px}
.card:hover img{transform:scale(1.08)}
.card:hover .btn{background:#fff;color:#000}
@media(max-width:749px){
.mobile-1{grid-template-columns:1fr}
.mobile-2{grid-template-columns:repeat(2,1fr)}
.content{left:16px;bottom:16px}
.content h3{font-size:18px}
.content p{font-size:13px}
.btn{padding:8px 12px;font-size:12px}
}
</style>

{% schema %}
{
  "name":"Premium Collection Grid",
  "settings":[
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Shop by Category"
    },
    {
      "type":"text",
      "id":"subheading",
      "label":"Subheading",
      "default":"Discover our premium collections"
    },
    {
      "type":"select",
      "id":"desktop_columns",
      "label":"Desktop Columns",
      "default":"3",
      "options":[
        {"value":"2","label":"2"},
        {"value":"3","label":"3"},
        {"value":"4","label":"4"}
      ]
    },
    {
      "type":"select",
      "id":"mobile_columns",
      "label":"Mobile Columns",
      "default":"2",
      "options":[
        {"value":"1","label":"1"},
        {"value":"2","label":"2"}
      ]
    },
    {
      "type":"text",
      "id":"button_text",
      "label":"Button Text",
      "default":"Shop Now"
    }
  ],
  "blocks":[
    {
      "type":"collection",
      "name":"Collection Card",
      "settings":[
        {
          "type":"collection",
          "id":"collection",
          "label":"Collection"
        },
        {
          "type":"image_picker",
          "id":"image",
          "label":"Custom Image"
        },
        {
          "type":"text",
          "id":"title",
          "label":"Custom Title"
        },
        {
          "type":"text",
          "id":"subtitle",
          "label":"Subtitle"
        }
      ]
    }
  ],
  "max_blocks":12,
  "presets":[
    {
      "name":"Premium Collection Grid"
    }
  ]
}
{% endschema %}
